/* =============================================
   public/css/admin.css  —  Panel Administrateur
   ============================================= */

.admin-body { display: flex; min-height: 100vh; background: var(--bg); overflow: hidden; }

/* ─── SIDEBAR ─────────────────────────────────────────────── */
.admin-sidebar { width: 240px; flex-shrink: 0; background: var(--bg-2); border-right: 1px solid var(--border); display: flex; flex-direction: column; height: 100vh; overflow-y: auto; position: sticky; top: 0; }
.sidebar-brand { padding: 1.25rem 1.25rem 0.75rem; border-bottom: 1px solid var(--border); display: flex; flex-direction: column; gap: 0.3rem; }
.sidebar-brand a { font-size: 1rem; font-weight: 800; color: var(--text); }
.sidebar-nav { padding: 0.75rem; flex: 1; display: flex; flex-direction: column; gap: 0.15rem; }
.sidebar-section { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; color: var(--text-muted); padding: 0.75rem 0.5rem 0.2rem; letter-spacing: 0.08em; }
.sidebar-link { display: block; padding: 0.5rem 0.75rem; border-radius: var(--radius-sm); font-size: 0.875rem; color: var(--text-muted); transition: all 0.15s; }
.sidebar-link:hover, .sidebar-link.active { background: var(--bg-3); color: var(--text); }
.sidebar-footer { padding: 1rem; border-top: 1px solid var(--border); display: flex; gap: 0.5rem; flex-wrap: wrap; }

/* ─── MAIN ────────────────────────────────────────────────── */
.admin-main { flex: 1; display: flex; flex-direction: column; min-width: 0; overflow-y: auto; }
.admin-header { padding: 1rem 2rem; background: var(--bg-2); border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; position: sticky; top: 0; z-index: 50; }
.admin-title { font-size: 1.1rem; font-weight: 700; }
.admin-user { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; color: var(--text-muted); }
.admin-content { padding: 2rem; flex: 1; }

/* ─── STAT CARDS ──────────────────────────────────────────── */
.stats-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
.stat-card { background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; display: flex; align-items: center; gap: 1rem; }
.stat-icon { font-size: 2rem; }
.stat-val { font-size: 1.75rem; font-weight: 800; display: block; color: var(--accent); }
.stat-label { font-size: 0.8rem; color: var(--text-muted); }

/* ─── DASHBOARD PANELS ────────────────────────────────────── */
.dashboard-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
.dashboard-panel, .admin-panel { background: var(--bg-2); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; }
.dashboard-panel h3, .admin-panel h3 { font-size: 0.95rem; font-weight: 700; margin-bottom: 1rem; color: var(--text-muted); }

/* ─── STATS LIST ──────────────────────────────────────────── */
.stats-list { display: flex; flex-direction: column; gap: 0.3rem; }
.stats-row { display: flex; justify-content: space-between; align-items: center; padding: 0.4rem 0.5rem; border-radius: var(--radius-sm); }
.stats-row:hover { background: var(--bg-3); }
.stats-action { font-family: var(--font-mono); font-size: 0.78rem; color: var(--text-muted); }

/* ─── ADMIN TABLE ─────────────────────────────────────────── */
.admin-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.admin-table th { text-align: left; padding: 0.6rem 0.875rem; background: var(--bg-3); border-bottom: 1px solid var(--border); font-weight: 600; font-size: 0.78rem; color: var(--text-muted); white-space: nowrap; }
.admin-table td { padding: 0.