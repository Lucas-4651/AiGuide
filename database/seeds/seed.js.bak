// ------------------------------------------------------------------
//  Lancement du seed
// ------------------------------------------------------------------
async function run() {
  console.log('\n🚀 Lancement du seed enrichi...\n');
  try {
    await seedAdmin();
    await seedAIs();
    await seedContent();
    await seedRoadmap();
    console.log('\n✅ Seed terminé avec succès !');
    console.log('🔑 Compte admin : admin@aiguide.com / admin123');
    await db2.destroy();
  } catch (e) {
    console.error('\n❌ Erreur seed:', e.message);
    process.exit(1);
  }
}

run();