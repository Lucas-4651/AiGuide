    // Productivity
    { name: 'Notion AI', slug: 'notion-ai', type: 'productivity', provider: 'Notion', pricing: 'paid', price: '10$/mois en supplément', desc_courte: 'Assistance IA dans les espaces de travail Notion', desc: 'Notion AI aide à rédiger, résumer, brainstormer et organiser le contenu directement dans Notion.', strengths: ['Intégration native', 'Gain de temps', 'Contextuel'], limitations: ['Payant', 'Nécessite Notion'], use_cases: ['Prise de notes', 'Gestion de projet', 'Rédaction'], tags: ['productivity', 'writing', 'notion'] },
    { name: 'Grammarly', slug: 'grammarly', type: 'productivity', provider: 'Grammarly', pricing: 'freemium', price: 'Gratuit / Premium 12$/mois', desc_courte: 'Assistant d\'écriture et de correction', desc: 'Grammarly améliore votre écriture en corrigeant la grammaire, le ton et la clarté, sur le web et dans les applications.', strengths: ['Correction précise', 'Suggestions de style', 'Multi-plateforme'], limitations: ['Version gratuite limitée'], use_cases: ['Rédaction', 'Correction', 'Communication professionnelle'], tags: ['writing', 'grammar', 'productivity'] },
    { name: 'Jasper', slug: 'jasper', type: 'productivity', provider: 'Jasper', pricing: 'paid', price: 'À partir de 39$/mois', desc_courte: 'Assistant de rédaction marketing', desc: 'Jasper aide à créer du contenu marketing, des articles de blog, des emails, etc., avec des modèles spécifiques.', strengths: ['Modèles marketing', 'Qualité rédactionnelle', 'Intégrations'], limitations: ['Cher', 'Pas de version gratuite'], use_cases: ['Marketing de contenu', 'Copywriting', 'Blog'], tags: ['writing', 'marketing', 'content'] },
    { name: 'Copy.ai', slug: 'copy-ai', type: 'productivity', provider: 'Copy.ai', pricing: 'freemium', price: 'Gratuit / Pro 36$/mois', desc_courte: 'Générateur de textes marketing', desc: 'Copy.ai permet de générer rapidement des textes pour les réseaux sociaux, emails, descriptions de produits.', strengths: ['Rapide', 'Interface simple', 'Bon pour les réseaux sociaux'], limitations: ['Moins de profondeur'], use_cases: ['Rédaction marketing', 'Emails', 'Slogans'], tags: ['writing', 'marketing', 'social'] },
    { name: 'Writesonic', slug: 'writesonic', type: 'productivity', provider: 'Writesonic', pricing: 'freemium', price: 'Gratuit / Pro à partir de 16$/mois', desc_courte: 'Assistant de rédaction polyvalent', desc: 'Writesonic génère des articles, publicités, emails, etc., avec intégration de données SEO.', strengths: ['SEO', 'Multi-format', 'Générateur d\'images intégré'], limitations: ['Qualité variable'], use_cases: ['SEO', 'Blog', 'Publicités'], tags: ['writing', 'seo', 'content'] },

    // Specialized
    { name: 'Elicit', slug: 'elicit', type: 'research', provider: 'Elicit', pricing: 'free', price: 'Gratuit', desc_courte: 'Assistant de recherche académique', desc: 'Elicit aide à trouver et analyser des articles scientifiques, en répondant à des questions avec des résumés.', strengths: ['Recherche ciblée', 'Résumés d\'articles', 'Gain de temps'], limitations: ['Base de données limitée à certains domaines'], use_cases: ['Recherche académique', 'Revue de littérature'], tags: ['research', 'academic', 'science'] },
    { name: 'Consensus', slug: 'consensus', type: 'research', provider: 'Consensus', pricing: 'freemium', price: 'Gratuit / Pro 10$/mois', desc_courte: 'Moteur de recherche pour la science', desc: 'Consensus répond à des questions en se basant sur des millions d\'articles scientifiques et affiche le consensus.', strengths: ['Basé sur des études', 'Indique le consensus', 'Fiabilité'], limitations: ['Nécessite des questions factuelles'], use_cases: ['Recherche scientifique', 'Vérification de faits'], tags: ['research', 'science', 'consensus'] },
    { name: 'Scite', slug: 'scite', type: 'research', provider: 'Scite', pricing: 'paid', price: 'À partir de 10$/mois', desc_courte: 'Plateforme d\'analyse de citations', desc: 'Scite montre comment un article a été cité (support, contraste, mention) pour évaluer l\'impact.', strengths: ['Analyse des citations', 'Visualisation', 'Assistant IA'], limitations: ['Payant'], use_cases: ['Recherche', 'Évaluation d\'articles'], tags: ['research', 'citations', 'analysis'] },
    { name: 'Gamma', slug: 'gamma', type: 'productivity', provider: 'Gamma', pricing: 'freemium', price: 'Gratuit / Pro 8$/mois', desc_courte: 'Création de présentations et documents par IA', desc: 'Gamma génère des présentations, documents et pages web à partir d\'une simple invite, avec un design soigné.', strengths: ['Génération rapide', 'Design élégant', 'Facile à utiliser'], limitations: ['Personnalisation limitée en gratuit'], use_cases: ['Présentations', 'Documentation', 'Sites simples'], tags: ['presentation', 'design', 'productivity'] },
    { name: 'Tome', slug: 'tome', type: 'productivity', provider: 'Tome', pricing: 'freemium', price: 'Gratuit / Pro 8$/mois', desc_courte: 'Outil de narration et présentations IA', desc: 'Tome aide à créer des récits visuels et des présentations avec des layouts générés par IA.', strengths: ['Narration fluide', 'Visuels intégrés', 'Collaboratif'], limitations: ['Moins de contrôle précis'], use_cases: ['Pitchs', 'Storytelling', 'Présentations'], tags: ['presentation', 'storytelling', 'design'] }
  ];

  // Combiner et générer les champs manquants pour chaque outil
  const allTools = [...baseTools, ...additionalTools].map(tool => {
    // Si certains champs ne sont pas définis, on les crée avec des valeurs par défaut basées sur le type
    const type = tool.type || 'text_generation';
    const provider = tool.provider || tool.name;
    const pricing_type = tool.pricing || 'freemium';
    const price_info = tool.price || 'Variable';
    const short_description = tool.desc_courte || `${tool.name} est un outil d'IA de type ${type}.`;
    const description = tool.desc || `${tool.name} est un outil d'IA spécialisé dans ${type}. Découvrez ses fonctionnalités sur son site officiel.`;

    // Forcer les champs JSON à être des chaînes
    const strengths = tool.strengths ? JSON.stringify(tool.strengths) : JSON.stringify(['Fonctionnalités avancées', 'Interface intuitive', 'Communauté active']);
    const limitations = tool.limitations ? JSON.stringify(tool.limitations) : JSON.stringify(['Courbe d\'apprentissage', 'Version gratuite limitée', 'Disponibilité']);
    const use_cases = tool.use_cases ? JSON.stringify(tool.use_cases) : JSON.stringify(['Création de contenu', 'Productivité', 'Expérimentation']);
    const tags = tool.tags ? JSON.stringify(tool.tags) : JSON.stringify([type, 'ai']);

    // Niveau de difficulté par défaut selon le type
    let difficulty = tool.difficulty_level || 'beginner';
    if (!tool.difficulty_level) {
      if (type.includes('advanced') || type === 'code_assistant' || type === 'video_generation') difficulty = 'intermediate';
      else difficulty = 'beginner';
    }

    return {
      name: tool.name,
      slug: tool.slug,
      short_description,
      description,
      type,
      provider,
      website_url: tool.website_url || `https://www.${tool.slug}.com`,
      pricing_type,
      price_info,
      strengths,
      limitations,
      use_cases,
      tags,
      difficulty_level: difficulty,
      is_featured: tool.is_featured !== undefined ? tool.is_featured : Math.random() < 0.2, // 20% de chance d'être mis en avant
      is_active: true,
      view_count: 0,
      created_at: now,
      updated_at: now
    };
  });

  return allTools;
}

