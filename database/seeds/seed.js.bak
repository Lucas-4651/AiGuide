// ------------------------------------------------------------------
//  Seed IA (ajoute uniquement celles qui n'existent pas encore)
// ------------------------------------------------------------------
async function seedAIs() {
  const existingSlugs = await db2('ai_tools').pluck('slug');
  console.log(`  [INFO] ${existingSlugs.length} IA existantes dans la base`);

  const allTools = generateAIToolsList();
  const newTools = allTools.filter(tool => !existingSlugs.includes(tool.slug));

  if (newTools.length === 0) {
    console.log('  [SKIP] Aucune nouvelle IA à ajouter');
    return;
  }

  // Insertion par lots pour éviter les timeout
  const batchSize = 20;
  for (let i = 0; i < newTools.length; i += batchSize) {
    const batch = newTools.slice(i, i + batchSize);
    await db2('ai_tools').insert(batch);
    console.log(`  [OK] Lot ${Math.floor(i/batchSize)+1} : ${batch.length} IA insérées`);
  }
  console.log(`  [OK] Total de ${newTools.length} nouvelles IA ajoutées (${existingSlugs.length + newTools.length} au total)`);
}

// ------------------------------------------------------------------
//  Seed contenus pédagogiques (flashcards, astuces, paramètres)
// ------------------------------------------------------------------
async function seedContent() {
  // Flashcards
  const cards = await db2('flash_cards').count('id as c').first();
  if (Number(cards.c) === 0) {
    const now = new Date().toISOString();
    await db2('flash_cards').insert([
      { term: 'LLM', definition: 'Large Language Model — modèle de langage entraîné sur de très grands corpus de texte pour prédire et générer du texte.', category: 'fondamentaux', difficulty: 1, order_index: 1, is_active: true, created_at: now },
      { term: 'Prompt', definition: 'Instruction ou question donnée à un modèle IA pour orienter sa réponse. La qualité du prompt influence directement la qualité du résultat.', category: 'fondamentaux', difficulty: 1, order_index: 2, is_active: true, created_at: now },
      { term: 'Token', definition: 'Unité de base du texte pour les LLMs. 1 token ≈ 4 caractères ou 3/4 de mot. Les modèles ont une limite de tokens par requête.', category: 'technique', difficulty: 2, example: 'Le mot "bonjour" = 1-2 tokens selon le modèle.', order_index: 3, is_active: true, created_at: now },
      { term: 'Hallucination', definition: 'Quand un LLM génère des informations fausses ou inventées avec un niveau de confiance élevé.', category: 'fondamentaux', difficulty: 1, example: 'Inventer une citation inexistante.', order_index: 4, is_active: true, created_at: now },
      { term: 'RAG', definition: 'Retrieval Augmented Generation — technique qui enrichit les réponses d\'un LLM avec des données externes récupérées en temps réel.', category: 'avancé', difficulty: 3, example: 'Connecter un LLM à votre base de documents.', order_index: 5, is_active: true, created_at: now },
      { term: 'Fine-tuning', definition: 'Entraînement supplémentaire d\'un modèle pré-entraîné sur un dataset spécifique pour l\'adapter à une tâche particulière.', category: 'avancé', difficulty: 3, order_index: 6, is_active: true, created_at: now },
      { term: 'Temperature', definition: 'Paramètre (0 à 2) qui contrôle la créativité des réponses. Basse = prévisible, haute = créatif.', category: 'technique', difficulty: 2, example: 'Temperature 0 pour du code, 0.9 pour de la poésie.', order_index: 7, is_active: true, created_at: now },
      { term: 'Embeddings', definition: 'Représentations vectorielles de texte qui capturent le sens sémantique, utilisées pour la recherche de similarité.', category: 'technique', difficulty: 3, order_index: 8, is_active: true, created_at: now },
      { term: 'Zero-shot', definition: 'Capacité d\'un modèle à effectuer une tâche sans avoir vu d\'exemple spécifique lors de l\'entraînement.', category: 'technique', difficulty: 2, order_index: 9, is_active: true, created_at: now },
      { term: 'Few-shot', definition: 'Technique où on fournit quelques exemples dans le prompt pour guider le modèle.', category: 'technique', difficulty: 2, order_index: 10, is_active: true, created_at: now },
      { term: 'Chain-of-Thought', definition: 'Méthode de prompting qui incite le modèle à raisonner étape par étape avant de répondre.', category: 'avancé', difficulty: 3, order_index: 11, is_active: true, created_at: now },
      { term: 'Multimodal', definition: 'Modèle capable de traiter plusieurs types de données (texte, image, audio, vidéo).', category: 'fondamentaux', difficulty: 2, order_index: 12, is_active: true, created_at: now }
    ]);
    console.log('  [OK] Flashcards insérées (12)');
  } else {
    console.log('  [SKIP] Flashcards déjà présentes');
  }

  // Tips
  const tips = await db2('tips').count('id as c').first();
  if (Number(tips.c) === 0) {
    const now = new Date().toISOString();
    await db2('tips').insert([
      { title: 'Sois spécifique', content: 'Plus ton prompt est précis, meilleure sera la réponse. Évite les questions vagues.', category: 'prompting', difficulty: 'beginner', order_index: 1, is_active: true, created_at: now },
      { title: 'Donne un rôle', content: 'Dis à l\'IA qui elle est : "Tu es un expert en cybersécurité..." change la qualité de la réponse.', category: 'prompting', difficulty: 'beginner', order_index: 2, is_active: true, created_at: now },
      { title: 'Spécifie le format', content: 'Demande explicitement le format voulu : liste, tableau, JSON, code...', category: 'prompting', difficulty: 'beginner', order_index: 3, is_active: true, created_at: now },
      { title: 'Utilise des exemples', content: 'La technique "few-shot" consiste à donner 2-3 exemples avant la vraie question.', category: 'prompting', difficulty: 'intermediate', order_index: 4, is_active: true, created_at: now },
      { title: 'Décompose les tâches complexes', content: 'Pour les tâches complexes, demande à l\'IA de réfléchir étape par étape.', category: 'prompting', difficulty: 'intermediate', order_index: 5, is_active: true, created_at: now },
      { title: 'Itère et affine', content: 'Ne te contente pas de la première réponse. Pose des questions de suivi pour améliorer le résultat.', category: 'général', difficulty: 'beginner', order_index: 6, is_active: true, created_at: now },
      { title: 'Utilise la température', content: 'Si tu veux des réponses créatives, augmente la température. Pour des faits précis, baisse-la.', category: 'technique', difficulty: 'intermediate', order_index: 7, is_active: true, created_at: now },
      { title: 'Vérifie les sources', content: 'Les LLM peuvent halluciner. Utilise des outils avec recherche web pour vérifier.', category: 'général', difficulty: 'beginner', order_index: 8, is_active: true, created_at: now }
    ]);
    console.log('  [OK] Tips insérés (8)');
  } else {
    console.log('  [SKIP] Tips déjà présents');
  }

  // Site settings
  const settings = await db2('site_settings').count('id as c').first();
  if (Number(settings.c) === 0) {
    await db2('site_settings').insert([
      { key: 'site_name',            value: 'AI Guide',                      description: 'Nom du site' },
      { key: 'site_tagline',         value: 'Du débutant à l\'expert en IA', description: 'Tagline affichée sur la homepage' },
      { key: 'guest_prompt_limit',   value: '3',                             description: 'Nombre de prompts gratuits/jour pour les visiteurs' },
      { key: 'site_description',     value: 'La plateforme de référence pour apprendre et maîtriser l\'IA', description: 'Meta description SEO' },
      { key: 'contact_email',        value: 'contact@aiguide.com',           description: 'Email de contact' },
      { key: 'enable_registration',  value: 'true',                          description: 'Autoriser les inscriptions' }
    ]);
    console.log('  [OK] Settings insérés (6)');
  } else {
    console.log('  [SKIP] Settings déjà présents');
  }
}

