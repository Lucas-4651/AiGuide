// ============================================================
//  database/seeds/seed.js
//  Lance avec : npm run seed
//  Version enrichie : plus de 40 IA, contenu pédagogique étendu
// ============================================================
require('dotenv').config();

const forcePG = process.argv.includes('--pg') || process.env.NODE_ENV === 'production';

let db;
if (forcePG) {
  if (!process.env.DATABASE_URL) {
    console.error('❌  DATABASE_URL manquant dans .env');
    process.exit(1);
  }
  const knex = require('knex');
  db = knex({
    client: 'pg',
    connection: {
      connectionString: process.env.DATABASE_URL,
      ssl: { rejectUnauthorized: false }
    }
  });
  console.log('🔌  Connecté à PostgreSQL (Neon)');
} else {
  db = require('../../src/config/database');
  console.log('🔌  Connecté à SQLite local');
}

const bcrypt = require('bcryptjs');


