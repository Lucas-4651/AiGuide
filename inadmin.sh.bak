#!/bin/bash
# =============================================================
#  ADMIN COMPLET — Backend + Vues
#  Lance depuis la racine du projet : bash install-admin-complet.sh
# =============================================================
mkdir -p views/layouts views/admin/ais views/admin/users views/admin/logs views/admin/content views/admin/roadmaps
mkdir -p src/controllers src/routes

echo "▶ Création du controller admin complet..."

# =============================================================
# src/controllers/adminController.js
# =============================================================
cat > src/controllers/adminController.js << 'CTRL'
const passport = require('passport');
const { User, AI, Prompt, FlashCard, Roadmap, Tip, Log, Setting } = require('../models');

// ─── AUTH ADMIN ───────────────────────────────────────────────
exports.showAdminLogin = (req, res) => {
  if (req.isAuthenticated() && req.user.role === 'admin') return res.redirect('/admin');
  res.render('admin/login', {
    layout: false,
    title: 'Admin Login',
    error_msg: req.flash('error'),
    success_msg: req.flash('success')
  });
};

exports.adminLogin = (req, res, next) => {
  passport.authenticate('local', (err, user, info) => {
    if (err) return next(err);
    if (!user) { req.flash('error', info ? info.message : 'Identifiants incorrects'); return res.redirect('/admin/login'); }
    if (user.role !== 'admin') { req.flash('error', 'Accès refusé — compte non administrateur'); return res.redirect('/admin/login'); }
    if (!user.is_active) { req.flash('error', 'Compte désactivé'); return res.redirect('/admin/login'); }
    req.logIn(user, async (err) => {
      if (err) return next(err);
      await Log.create({ user_id: user.id, action: 'ADMIN_LOGIN', ip_address: req.ip, created_at: new Date().toISOString() }).catch(() => {});
      res.redirect('/admin');
    });
  })(req, res, next);
};

exports.adminLogout = (req, res, next) => {
  req.logout((err) => { if (err) return next(err); res.redirect('/admin/login'); });
};

// ─── DASHBOARD ────────────────────────────────────────────────
exports.dashboard = async (req, res, next) => {
  try {
    const [userCount, aiCount, promptCount, logCount, recentLogs, recentPrompts, logStats] = await Promise.all([
      User.count(), AI.count(), Prompt.count(), Log.count(),
      Log.recent(10), Prompt.recent(5), Log.stats()
    ]);
    res.render('admin/dashboard', {
      layout: 'layouts/admin', title: 'Dashboard',
      stats: { users: userCount, ais: aiCount, prompts: promptCount, logs: logCount },
      recentLogs, recentPrompts, logStats
    });
  } catch (e) { next(e); }
};

// ─── IAs ──────────────────────────────────────────────────────
exports.listAIs = async (req, res, next) => {
  try {
    const ais = await AI.adminAll();
    res.render('admin/ais/index', { layout: 'layouts/admin', title: 'Gestion IAs', ais });
  } catch (e) { next(e); }
};

exports.newAIForm = (req, res) => {
  res.render('admin/ais/form', { layout: 'layouts/admin', title: 'Ajouter une IA', ai: null, action: '/admin/ais', method: 'POST' });
};

exports.createAI = async (req, res, next) => {
  try {
    const data = sanitizeAI(req.body);
    await AI.create(data);
    req.flash('success', 'IA "' + data.name + '" ajoutée');
    res.redirect('/admin/ais');
  } catch (e) { req.flash('error', 'Erreur: ' + e.message); res.redirect('/admin/ais/new'); }
};

exports.editAIForm = async (req, res, next) => {
  try {
    const ai = await AI.byId(req.params.id);
    if (!ai) { req.flash('error', 'IA introuvable'); return res.redirect('/admin/ais'); }
    res.render('admin/ais/form', { layout: 'layouts/admin', title: 'Modifier ' + ai.name, ai, action: '/admin/ais/' + ai.id + '?_method=PUT', method: 'POST' });
  } catch (e) { next(e); }
};

exports.updateAI = async (req, res, next) => {
  try {
    await AI.update(req.params.id, sanitizeAI(req.body));
    req.flash('success', 'IA mise à jour');
    res.redirect('/admin/ais');
  } catch (e) { next(e); }
};

exports.deleteAI = async (req, res, next) => {
  try {
    await AI.delete(req.params.id);
    req.flash('success', 'IA supprimée');
    res.redirect('/admin/ais');
  } catch (e) { next(e); }
};

function sanitizeAI(body) {
  const toJSON = (val) => {
    if (!val) return JSON.stringify([]);
    return JSON.stringify(val.split('\n').map((s) => s.trim()).filter(Boolean));
  };
  return {
    name: body.name,
    slug: body.slug || body.name.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, ''),
    description: body.description,
    short_description: body.short_description || '',
    type: body.type,
    provider: body.provider || '',
    website_url: body.website_url || '',
    pricing_type: body.pricing_type || 'free',
    price_info: body.price_info || '',
    strengths: toJSON(body.strengths),
    limitations: toJSON(body.limitations),
    use_cases: toJSON(body.use_cases),
    tags: toJSON(body.tags),
    logo_url: body.logo_url || '',
    difficulty_level: body.difficulty_level || 'beginner',
    is_featured: body.is_featured ? 1 : 0,
    is_active: body.is_active !== undefined ? (body.is_active ? 1 : 0) : 1,
    created_at: new Date().toISOString(),
    updated_at: new Date().toISOString()
  };
}

// ─── UTILISATEURS ─────────────────────────────────────────────
exports.listUsers = async (req, res, next) => {
  try {
    const page = parseInt(req.query.page) || 1;
    const users = await User.all(page, 20);
    const total = await User.count();
    res.render('admin/users/index', {
      layout: 'layouts/admin', title: 'Utilisateurs',
      users, total, page, pages: Math.ceil(total / 20)
    });
  } catch (e) { next(e); }
};

exports.viewUser = async (req, res, next) => {
  try {
    const u = await User.findById(req.params.id);
    if (!u) { req.flash('error', 'Utilisateur introuvable'); return res.redirect('/admin/users'); }
    const prompts = await Prompt.forUser(u.id, 20);
    const logs    = await Log.forUser(u.id);
    res.render('admin/users/detail', {
      layout: 'layouts/admin', title: 'Utilisateur : ' + u.username,
      u, prompts, logs
    });
  } catch (e) { next(e); }
};

exports.toggleUser = async (req, res, next) => {
  try {
    const user = await User.findById(req.params.id);
    if (!user) { req.flash('error', 'Introuvable'); return res.redirect('/admin/users'); }
    if (user.id === req.user.id) { req.flash('error', 'Tu ne peux pas te désactiver toi-même'); return res.redirect('/admin/users'); }
    await User.update(user.id, { is_active: user.is_active ? 0 : 1 });
    req.flash('success', 'Statut mis à jour');
    res.redirect('/admin/users');
  } catch (e) { next(e); }
};

exports.changeRole = async (req, res, next) => {
  try {
    const user = await User.findById(req.params.id);
    if (!user || user.id === req.user.id) { req.flash('error', 'Action impossible'); return res.redirect('/admin/users'); }
    const newRole = user.role === 'admin' ? 'user' : 'admin';
    await User.update(user.id, { role: newRole });
    req.flash('success', 'Rôle mis à jour : ' + newRole);
    res.redirect('/admin/users');
  } catch (e) { next(e); }
};

exports.deleteUser = async (req, res, next) => {
  try {
    const user = await User.findById(req.params.id);
    if (!user || user.id === req.user.id) { req.flash('error', 'Action impossible'); return res.redirect('/admin/users'); }
    await User.delete(req.params.id);
    req.flash('success', 'Utilisateur supprimé');
    res.redirect('/admin/users');
  } catch (e) { next(e); }
};

// ─── PROMPTS ──────────────────────────────────────────────────
exports.listPrompts = async (req, res, next) => {
  try {
    const prompts = await Prompt.recent(50);
    res.render('admin/prompts/index', { layout: 'layouts/admin', title: 'Tous les Prompts', prompts });
  } catch (e) { next(e); }
};

exports.deletePrompt = async (req, res, next) => {
  try {
    await Prompt.delete(req.params.id);
    req.flash('success', 'Prompt supprimé');
    res.redirect('/admin/prompts');
  } catch (e) { next(e); }
};

// ─── FLASH CARDS ──────────────────────────────────────────────
exports.listFlashCards = async (req, res, next) => {
  try {
    const cards = await FlashCard.adminAll();
    res.render('admin/content/flashcards', { layout: 'layouts/admin', title: 'Flash Cards', cards });
  } catch (e) { next(e); }
};

exports.createFlashCard = async (req, res, next) => {
  try {
    await FlashCard.create({ ...req.body, is_active: 1, created_at: new Date().toISOString() });
    req.flash('success', 'Flash card ajoutée');
    res.redirect('/admin/content/flashcards');
  } catch (e) { next(e); }
};

exports.editFlashCardForm = async (req, res, next) => {
  try {
    const card = await FlashCard.adminAll().then(cards => cards.find(c => c.id == req.params.id));
    if (!card) { req.flash('error', 'Carte introuvable'); return res.redirect('/admin/content/flashcards'); }
    res.render('admin/content/flashcard-edit', { layout: 'layouts/admin', title: 'Modifier la carte', card });
  } catch (e) { next(e); }
};

exports.updateFlashCard = async (req, res, next) => {
  try {
    await FlashCard.update(req.params.id, req.body);
    req.flash('success', 'Flash card mise à jour');
    res.redirect('/admin/content/flashcards');
  } catch (e) { next(e); }
};

exports.deleteFlashCard = async (req, res, next) => {
  try {
    await FlashCard.delete(req.params.id);
    req.flash('success', 'Flash card supprimée');
    res.redirect('/admin/content/flashcards');
  } catch (e) { next(e); }
};

// ─── TIPS ─────────────────────────────────────────────────────
exports.listTips = async (req, res, next) => {
  try {
    const tips = await Tip.adminAll();
    res.render('admin/content/tips', { layout: 'layouts/admin', title: 'Astuces', tips });
  } catch (e) { next(e); }
};

exports.createTip = async (req, res, next) => {
  try {
    await Tip.create({ ...req.body, is_active: 1, created_at: new Date().toISOString() });
    req.flash('success', 'Astuce ajoutée');
    res.redirect('/admin/content/tips');
  } catch (e) { next(e); }
};

exports.editTipForm = async (req, res, next) => {
  try {
    const tips = await Tip.adminAll();
    const tip = tips.find(t => t.id == req.params.id);
    if (!tip) { req.flash('error', 'Astuce introuvable'); return res.redirect('/admin/content/tips'); }
    res.render('admin/content/tip-edit', { layout: 'layouts/admin', title: 'Modifier l\'astuce', tip });
  } catch (e) { next(e); }
};

exports.updateTip = async (req, res, next) => {
  try {
    await Tip.update(req.params.id, req.body);
    req.flash('success', 'Astuce mise à jour');
    res.redirect('/admin/content/tips');
  } catch (e) { next(e); }
};

exports.deleteTip = async (req, res, next) => {
  try {
    await Tip.delete(req.params.id);
    req.flash('success', 'Astuce supprimée');
    res.redirect('/admin/content/tips');
  } catch (e) { next(e); }
};

// ─── ROADMAPS ─────────────────────────────────────────────────
exports.listRoadmaps = async (req, res, next) => {
  try {
    const roadmaps = await Roadmap.adminAll();
    res.render('admin/roadmaps/index', { layout: 'layouts/admin', title: 'Roadmaps', roadmaps });
  } catch (e) { next(e); }
};

exports.newRoadmapForm = (req, res) => {
  res.render('admin/roadmaps/form', { layout: 'layouts/admin', title: 'Ajouter une Roadmap', roadmap: null, action: '/admin/roadmaps', method: 'POST' });
};

exports.createRoadmap = async (req, res, next) => {
  try {
    const steps = (req.body.steps || '').split('\n').map(s => s.trim()).filter(Boolean).map(s => ({ title: s, description: '', resource: '' }));
    await Roadmap.create({
      title: req.body.title,
      description: req.body.description,
      level: req.body.level,
      target_audience: req.body.target_audience || '',
      estimated_duration: req.body.estimated_duration || '',
      steps: JSON.stringify(steps),
      is_active: 1,
      created_at: new Date().toISOString()
    });
    req.flash('success', 'Roadmap créée');
    res.redirect('/admin/roadmaps');
  } catch (e) { next(e); }
};

exports.editRoadmapForm = async (req, res, next) => {
  try {
    const roadmap = await Roadmap.byId(req.params.id);
    if (!roadmap) { req.flash('error', 'Roadmap introuvable'); return res.redirect('/admin/roadmaps'); }
    res.render('admin/roadmaps/form', { layout: 'layouts/admin', title: 'Modifier ' + roadmap.title, roadmap, action: '/admin/roadmaps/' + roadmap.id + '?_method=PUT', method: 'POST' });
  } catch (e) { next(e); }
};

exports.updateRoadmap = async (req, res, next) => {
  try {
    const steps = (req.body.steps || '').split('\n').map(s => s.trim()).filter(Boolean).map(s => ({ title: s, description: '', resource: '' }));
    await Roadmap.update(req.params.id, {
      title: req.body.title,
      description: req.body.description,
      level: req.body.level,
      target_audience: req.body.target_audience || '',
      estimated_duration: req.body.estimated_duration || '',
      steps: JSON.stringify(steps),
      updated_at: new Date().toISOString()
    });
    req.flash('success', 'Roadmap mise à jour');
    res.redirect('/admin/roadmaps');
  } catch (e) { next(e); }
};

exports.deleteRoadmap = async (req, res, next) => {
  try {
    await Roadmap.delete(req.params.id);
    req.flash('success', 'Roadmap supprimée');
    res.redirect('/admin/roadmaps');
  } catch (e) { next(e); }
};

// ─── LOGS ─────────────────────────────────────────────────────
exports.logs = async (req, res, next) => {
  try {
    const [logs, stats] = await Promise.all([Log.recent(100), Log.stats()]);
    res.render('admin/logs/index', { layout: 'layouts/admin', title: 'Logs & Métriques', logs, stats });
  } catch (e) { next(e); }
};

// ─── SETTINGS ─────────────────────────────────────────────────
exports.settings = async (req, res, next) => {
  try {
    const settings = await Setting.all();
    res.render('admin/settings', { layout: 'layouts/admin', title: 'Paramètres', settings });
  } catch (e) { next(e); }
};

exports.updateSettings = async (req, res, next) => {
  try {
    for (const [key, value] of Object.entries(req.body)) await Setting.set(key, value);
    req.flash('success', 'Paramètres sauvegardés');
    res.redirect('/admin/settings');
  } catch (e) { next(e); }
};

// ─── PROMPTS model patch ──────────────────────────────────────
// (au cas où Prompt.delete n'existe pas)
Prompt.delete = Prompt.delete || ((id) => require('../config/database')('prompts').where({ id }).delete());
CTRL

echo "  ✓ adminController.js"

# =============================================================
# src/routes/admin.js
# =============================================================
cat > src/routes/admin.js << 'ROUTES'
const express     = require('express');
const router      = express.Router();
const ctrl        = require('../controllers/adminController');
const { isAdmin } = require('../middlewares/auth');

// Login/Logout AVANT isAdmin
router.get('/login',  ctrl.showAdminLogin);
router.post('/login', ctrl.adminLogin);
router.get('/logout', ctrl.adminLogout);

// Tout ce qui suit = admin requis
router.use(isAdmin);

// Dashboard
router.get('/', ctrl.dashboard);

// IAs
router.get('/ais',             ctrl.listAIs);
router.get('/ais/new',         ctrl.newAIForm);
router.post('/ais',            ctrl.createAI);
router.get('/ais/:id/edit',    ctrl.editAIForm);
router.put('/ais/:id',         ctrl.updateAI);
router.delete('/ais/:id',      ctrl.deleteAI);

// Utilisateurs
router.get('/users',                ctrl.listUsers);
router.get('/users/:id',            ctrl.viewUser);
router.post('/users/:id/toggle',    ctrl.toggleUser);
router.post('/users/:id/role',      ctrl.changeRole);
router.delete('/users/:id',         ctrl.deleteUser);

// Prompts
router.get('/prompts',              ctrl.listPrompts);
router.delete('/prompts/:id',       ctrl.deletePrompt);

// Flash Cards
router.get('/content/flashcards',         ctrl.listFlashCards);
router.post('/content/flashcards',        ctrl.createFlashCard);
router.get('/content/flashcards/:id/edit', ctrl.editFlashCardForm);
router.put('/content/flashcards/:id',     ctrl.updateFlashCard);
router.delete('/content/flashcards/:id',  ctrl.deleteFlashCard);

// Tips
router.get('/content/tips',          ctrl.listTips);
router.post('/content/tips',         ctrl.createTip);
router.get('/content/tips/:id/edit', ctrl.editTipForm);
router.put('/content/tips/:id',      ctrl.updateTip);
router.delete('/content/tips/:id',   ctrl.deleteTip);

// Roadmaps
router.get('/roadmaps',             ctrl.listRoadmaps);
router.get('/roadmaps/new',         ctrl.newRoadmapForm);
router.post('/roadmaps',            ctrl.createRoadmap);
router.get('/roadmaps/:id/edit',    ctrl.editRoadmapForm);
router.put('/roadmaps/:id',         ctrl.updateRoadmap);
router.delete('/roadmaps/:id',      ctrl.deleteRoadmap);

// Logs & Settings
router.get('/logs',      ctrl.logs);
router.get('/settings',  ctrl.settings);
router.post('/settings', ctrl.updateSettings);

module.exports = router;
ROUTES

echo "  ✓ routes/admin.js"

# =============================================================
# views/layouts/admin.ejs — Design moderne et autonome
# =============================================================
cat > views/layouts/admin.ejs << 'LAYOUT'
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %> — AI Guide</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root{--bg:#0d0d14;--s:#13131f;--s2:#1a1a2e;--s3:#22223a;--bd:#2a2a45;--t:#f0f0fa;--t2:#9090b8;--m:#5050778;--a:#6c63ff;--a2:#22d3ee;--g:#22c55e;--r:#ef4444;--y:#f59e0b;--f:'Inter',sans-serif;--mono:'JetBrains Mono',monospace;--rad:8px}
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html,body{height:100%}
    body{font-family:var(--f);background:var(--bg);color:var(--t);display:flex;min-height:100vh}
    a{color:var(--a);text-decoration:none}
    a:hover{color:var(--a2)}
    code,pre{font-family:var(--mono)}

    /* SIDEBAR */
    .sb{width:230px;flex-shrink:0;background:var(--s);border-right:1px solid var(--bd);display:flex;flex-direction:column;height:100vh;position:sticky;top:0;overflow-y:auto}
    .sb-top{padding:1.25rem 1rem;border-bottom:1px solid var(--bd)}
    .sb-logo{display:flex;align-items:center;gap:.6rem;font-size:1rem;font-weight:700;color:var(--t);margin-bottom:.5rem}
    .sb-logo .dot{width:8px;height:8px;background:var(--a);border-radius:50%;display:inline-block}
    .sb-badge{font-size:.6rem;font-family:var(--mono);background:rgba(108,99,255,.15);border:1px solid rgba(108,99,255,.3);color:var(--a);padding:.15rem .5rem;border-radius:4px;letter-spacing:.08em;font-weight:600}
    .sb-nav{flex:1;padding:.5rem}
    .sb-sec{font-size:.62rem;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:#50507a;padding:.75rem .75rem .3rem}
    .sb-link{display:flex;align-items:center;gap:.6rem;padding:.5rem .75rem;border-radius:var(--rad);font-size:.83rem;color:var(--t2);transition:all .15s;margin-bottom:.05rem}
    .sb-link:hover{background:var(--s2);color:var(--t)}
    .sb-link.on{background:rgba(108,99,255,.12);color:var(--a);font-weight:500}
    .sb-link .i{width:18px;text-align:center;font-size:.95rem;flex-shrink:0}
    .sb-foot{padding:.75rem;border-top:1px solid var(--bd)}
    .sb-user{display:flex;align-items:center;gap:.6rem;padding:.6rem .75rem;background:var(--s2);border-radius:var(--rad);margin-bottom:.5rem}
    .sb-av{width:32px;height:32px;border-radius:50%;background:linear-gradient(135deg,var(--a),var(--a2));display:flex;align-items:center;justify-content:center;font-size:.78rem;font-weight:700;color:#fff;flex-shrink:0}
    .sb-uname{font-size:.8rem;font-weight:600;line-height:1.2}
    .sb-urole{font-size:.65rem;color:#50507a;font-family:var(--mono)}
    .sb-out{display:flex;align-items:center;justify-content:center;gap:.4rem;width:100%;padding:.45rem;border-radius:var(--rad);border:1px solid var(--bd);background:transparent;color:var(--t2);font-family:var(--f);font-size:.78rem;cursor:pointer;transition:all .15s;text-decoration:none}
    .sb-out:hover{background:rgba(239,68,68,.08);border-color:var(--r);color:var(--r)}

    /* MAIN */
    .main{flex:1;display:flex;flex-direction:column;min-width:0;height:100vh;overflow-y:auto}
    .topbar{height:52px;background:var(--s);border-bottom:1px solid var(--bd);display:flex;align-items:center;justify-content:space-between;padding:0 1.5rem;position:sticky;top:0;z-index:50;flex-shrink:0}
    .tb-title{font-size:.95rem;font-weight:600;display:flex;align-items:center;gap:.5rem}
    .tb-bc{font-size:.72rem;color:#50507a;font-family:var(--mono)}
    .tb-r{display:flex;align-items:center;gap:.75rem}
    .tb-pill{font-size:.72rem;padding:.25rem .6rem;border-radius:99px;background:var(--s2);border:1px solid var(--bd);color:var(--t2)}
    .tb-btn{font-size:.75rem;padding:.3rem .65rem;border-radius:var(--rad);border:1px solid var(--bd);color:var(--t2);transition:all .15s}
    .tb-btn:hover{border-color:var(--a);color:var(--a)}
    .content{padding:1.5rem;flex:1}

    /* ALERTS */
    .alert{display:flex;align-items:center;gap:.6rem;padding:.7rem 1rem;border-radius:var(--rad);margin-bottom:1rem;font-size:.83rem}
    .al-ok{background:rgba(34,197,94,.07);border:1px solid rgba(34,197,94,.2);color:var(--g)}
    .al-err{background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.2);color:var(--r)}
    .al-info{background:rgba(34,211,238,.07);border:1px solid rgba(34,211,238,.2);color:var(--a2)}

    /* STATS */
    .sg{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:.875rem;margin-bottom:1.5rem}
    .sc{background:var(--s);border:1px solid var(--bd);border-radius:var(--rad);padding:1.1rem;display:flex;gap:.875rem;align-items:center;transition:border-color .2s;cursor:default}
    .sc:hover{border-color:var(--a)}
    .si{width:40px;height:40px;border-radius:var(--rad);display:flex;align-items:center;justify-content:center;font-size:1.1rem;flex-shrink:0}
    .si.p{background:rgba(108,99,255,.1)}.si.c{background:rgba(34,211,238,.1)}.si.g{background:rgba(34,197,94,.1)}.si.y{background:rgba(245,158,11,.1)}
    .sv{font-size:1.7rem;font-weight:700;line-height:1}
    .sv.p{color:var(--a)}.sv.c{color:var(--a2)}.sv.g{color:var(--g)}.sv.y{color:var(--y)}
    .sl{font-size:.72rem;color:var(--t2);margin-top:.1rem}

    /* PANEL */
    .pg{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
    .pn{background:var(--s);border:1px solid var(--bd);border-radius:var(--rad);overflow:hidden}
    .ph{padding:.75rem 1rem;border-bottom:1px solid var(--bd);display:flex;justify-content:space-between;align-items:center}
    .ph h3{font-size:.8rem;font-weight:600;color:var(--t2)}
    .ph a{font-size:.72rem;color:var(--a)}
    .pb{padding:1rem}

    /* TABLE */
    .tbl{width:100%;border-collapse:collapse;font-size:.8rem}
    .tbl th{text-align:left;padding:.5rem .875rem;background:var(--s2);border-bottom:1px solid var(--bd);font-size:.68rem;font-weight:600;color:#50507a;text-transform:uppercase;letter-spacing:.06em;white-space:nowrap}
    .tbl td{padding:.65rem .875rem;border-bottom:1px solid var(--bd);vertical-align:middle}
    .tbl tr:last-child td{border-bottom:none}
    .tbl tr:hover td{background:rgba(255,255,255,.015)}
    .dim{opacity:.35}
    .ac{display:flex;gap:.3rem;align-items:center;flex-wrap:wrap}

    /* BUTTONS */
    .btn{display:inline-flex;align-items:center;gap:.3rem;padding:.4rem .875rem;border-radius:var(--rad);font-family:var(--f);font-size:.78rem;font-weight:500;cursor:pointer;border:none;transition:all .15s;text-decoration:none;white-space:nowrap;line-height:1.4}
    .btn-p{background:var(--a);color:#fff}.btn-p:hover{background:#5a52e8;color:#fff}
    .btn-o{background:transparent;color:var(--t2);border:1px solid var(--bd)}.btn-o:hover{border-color:var(--a);color:var(--a)}
    .btn-r{background:rgba(239,68,68,.08);color:var(--r);border:1px solid rgba(239,68,68,.2)}.btn-r:hover{background:var(--r);color:#fff;border-color:var(--r)}
    .btn-g{background:rgba(34,197,94,.08);color:var(--g);border:1px solid rgba(34,197,94,.2)}.btn-g:hover{background:var(--g);color:#fff;border-color:var(--g)}
    .btn-y{background:rgba(245,158,11,.08);color:var(--y);border:1px solid rgba(245,158,11,.2)}.btn-y:hover{background:var(--y);color:#fff;border-color:var(--y)}
    .btn-sm{padding:.28rem .6rem;font-size:.72rem}
    .btn-xs{padding:.18rem .45rem;font-size:.68rem}
    .btn-w{width:100%;justify-content:center}

    /* BADGES */
    .tag{display:inline-block;padding:.12rem .4rem;background:var(--s3);border:1px solid var(--bd);border-radius:4px;font-size:.67rem;color:var(--t2);font-family:var(--mono)}
    .bx{display:inline-block;padding:.12rem .45rem;border-radius:99px;font-size:.67rem;font-weight:600}
    .bx-a{background:rgba(108,99,255,.12);color:var(--a)}
    .bx-u{background:var(--s2);color:var(--t2)}
    .bx-g{background:rgba(34,197,94,.12);color:var(--g)}
    .bx-r{background:rgba(239,68,68,.12);color:var(--r)}
    .bx-y{background:rgba(245,158,11,.12);color:var(--y)}
    .bx-c{background:var(--s2);color:var(--t2);font-family:var(--mono)}
    .on-dot{color:var(--g);font-size:.75rem;font-weight:700}
    .off-dot{color:var(--r);font-size:.75rem;font-weight:700}
    .pr-free{color:var(--g);font-size:.75rem;font-weight:600}
    .pr-freemium{color:var(--a2);font-size:.75rem;font-weight:600}
    .pr-paid{color:var(--y);font-size:.75rem;font-weight:600}
    .pr-open_source{color:#86efac;font-size:.75rem;font-weight:600}

    /* TOOLBAR */
    .tb2{display:flex;justify-content:space-between;align-items:center;margin-bottom:1rem}
    .tb2-l,.tb2-r{display:flex;gap:.5rem;align-items:center}
    .pagi{display:flex;align-items:center;gap:.5rem;font-size:.75rem;color:var(--t2)}

    /* FORMS */
    .form{display:flex;flex-direction:column;gap:1.1rem;max-width:960px}
    .fg{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:.875rem}
    .fg3{display:grid;grid-template-columns:repeat(3,1fr);gap:.875rem}
    .fw{grid-column:1/-1}
    .fgrp{display:flex;flex-direction:column;gap:.3rem}
    .fgrp label{font-size:.68rem;font-weight:600;color:#50507a;text-transform:uppercase;letter-spacing:.06em}
    .fi,.fs,.ft{width:100%;padding:.5rem .75rem;background:var(--s2);border:1px solid var(--bd);border-radius:var(--rad);color:var(--t);font-family:var(--f);font-size:.83rem;transition:border-color .15s}
    .fi:focus,.fs:focus,.ft:focus{outline:none;border-color:var(--a)}
    .fi::placeholder{color:#50507a}
    .fs option{background:var(--s)}
    .ft{resize:vertical;min-height:80px}
    .fch{display:flex;gap:1.25rem;flex-wrap:wrap;align-items:center}
    .fcl{display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.83rem}
    .fcl input{accent-color:var(--a);width:14px;height:14px}
    .fa{display:flex;gap:.6rem;padding-top:.4rem}

    /* USER */
    .uc{display:flex;align-items:center;gap:.5rem}
    .uav{width:26px;height:26px;border-radius:50%;background:linear-gradient(135deg,var(--a),var(--a2));display:flex;align-items:center;justify-content:center;font-size:.68rem;font-weight:700;color:#fff;flex-shrink:0}

    /* MISC */
    .sl-list{display:flex;flex-direction:column}
    .sl-row{display:flex;justify-content:space-between;align-items:center;padding:.4rem 0;border-bottom:1px solid var(--bd)}
    .sl-row:last-child{border-bottom:none}
    .sl-act{font-family:var(--mono);font-size:.72rem;color:var(--t2)}
    .g2{display:grid;grid-template-columns:340px 1fr;gap:1.5rem;align-items:start}
    .mt{margin-top:1rem}
    .tx-m{color:var(--t2)}.tx-xs{font-size:.7rem}.tx-sm{font-size:.78rem}

    @media(max-width:1024px){.pg{grid-template-columns:1fr}.g2{grid-template-columns:1fr}.fg3{grid-template-columns:1fr 1fr}}
    @media(max-width:768px){.sb{display:none}.content{padding:1rem}.topbar{padding:0 1rem}.fg3{grid-template-columns:1fr}.sg{grid-template-columns:1fr 1fr}}
    @media(max-width:480px){.sg{grid-template-columns:1fr}}
  </style>
</head>
<body>

<aside class="sb">
  <div class="sb-top">
    <div class="sb-logo"><span class="dot"></span> AI Guide Admin</div>
    <span class="sb-badge">ADMINISTRATOR</span>
  </div>
  <nav class="sb-nav">
    <a href="/admin" class="sb-link <%= currentPath === '/admin' ? 'on' : '' %>"><span class="i">📊</span> Dashboard</a>
    <div class="sb-sec">Contenu</div>
    <a href="/admin/ais" class="sb-link <%= currentPath && currentPath.startsWith('/admin/ais') ? 'on' : '' %>"><span class="i">🤖</span> IAs</a>
    <a href="/admin/roadmaps" class="sb-link <%= currentPath && currentPath.startsWith('/admin/roadmaps') ? 'on' : '' %>"><span class="i">🗺️</span> Roadmaps</a>
    <a href="/admin/content/flashcards" class="sb-link <%= currentPath && currentPath.includes('flashcards') ? 'on' : '' %>"><span class="i">🃏</span> Flash Cards</a>
    <a href="/admin/content/tips" class="sb-link <%= currentPath && currentPath.includes('tips') ? 'on' : '' %>"><span class="i">💡</span> Astuces</a>
    <div class="sb-sec">Communauté</div>
    <a href="/admin/users" class="sb-link <%= currentPath && currentPath.startsWith('/admin/users') ? 'on' : '' %>"><span class="i">👥</span> Utilisateurs</a>
    <a href="/admin/prompts" class="sb-link <%= currentPath && currentPath.startsWith('/admin/prompts') ? 'on' : '' %>"><span class="i">⚡</span> Prompts</a>
    <div class="sb-sec">Système</div>
    <a href="/admin/logs" class="sb-link <%= currentPath === '/admin/logs' ? 'on' : '' %>"><span class="i">📋</span> Logs</a>
    <a href="/admin/settings" class="sb-link <%= currentPath === '/admin/settings' ? 'on' : '' %>"><span class="i">⚙️</span> Paramètres</a>
    <div class="sb-sec">Site</div>
    <a href="/" target="_blank" class="sb-link"><span class="i">🌐</span> Voir le site</a>
  </nav>
  <div class="sb-foot">
    <div class="sb-user">
      <div class="sb-av"><%= user ? user.username[0].toUpperCase() : 'A' %></div>
      <div>
        <div class="sb-uname"><%= user ? user.username : 'Admin' %></div>
        <div class="sb-urole">administrator</div>
      </div>
    </div>
    <a href="/admin/logout" class="sb-out">⏻ Déconnexion</a>
  </div>
</aside>

<div class="main">
  <header class="topbar">
    <div class="tb-title">
      <%= typeof title !== 'undefined' ? title : 'Admin' %>
      <span class="tb-bc">/ AI Guide</span>
    </div>
    <div class="tb-r">
      <span class="tb-pill"><%= user ? user.email : '' %></span>
      <a href="/" target="_blank" class="tb-btn">← Site public</a>
    </div>
  </header>
  <div class="content">
    <% if(typeof success_msg!=='undefined'&&success_msg&&success_msg.length>0){%><div class="alert al-ok">✓ <%= success_msg %></div><%}%>
    <% if(typeof error_msg!=='undefined'&&error_msg&&error_msg.length>0){%><div class="alert al-err">✕ <%= error_msg %></div><%}%>
    <% if(typeof info_msg!=='undefined'&&info_msg&&info_msg.length>0){%><div class="alert al-info">ℹ <%= info_msg %></div><%}%>
    <%- body %>
  </div>
</div>

<script>
  document.querySelectorAll('.alert').forEach(el=>setTimeout(()=>el.remove(),5000));
  const ni=document.querySelector('.fi[name="name"]'),si=document.querySelector('.fi[name="slug"]');
  if(ni&&si){ni.addEventListener('input',()=>{if(!si.dataset.m)si.value=ni.value.toLowerCase().trim().replace(/\s+/g,'-').replace(/[^a-z0-9-]/g,'')});si.addEventListener('input',()=>si.dataset.m='1')}
</script>
</body>
</html>
LAYOUT

echo "  ✓ layouts/admin.ejs"

# =============================================================
# views/admin/dashboard.ejs
# =============================================================
cat > views/admin/dashboard.ejs << 'V'
<div class="sg">
  <div class="sc"><div class="si p">🤖</div><div><div class="sv p"><%= stats.ais %></div><div class="sl">IAs enregistrées</div></div></div>
  <div class="sc"><div class="si c">👥</div><div><div class="sv c"><%= stats.users %></div><div class="sl">Utilisateurs</div></div></div>
  <div class="sc"><div class="si g">⚡</div><div><div class="sv g"><%= stats.prompts %></div><div class="sl">Prompts générés</div></div></div>
  <div class="sc"><div class="si y">📋</div><div><div class="sv y"><%= stats.logs %></div><div class="sl">Actions loggées</div></div></div>
</div>
<div class="pg">
  <div class="pn">
    <div class="ph"><h3>Activité récente</h3><a href="/admin/logs">Tout voir →</a></div>
    <table class="tbl">
      <thead><tr><th>Action</th><th>IP</th><th>Date</th></tr></thead>
      <tbody>
        <% (recentLogs||[]).forEach(l=>{%>
        <tr><td><code style="font-size:.72rem;color:var(--a2)"><%= l.action %></code></td><td class="tx-xs tx-m"><%= l.ip_address||'—' %></td><td class="tx-xs tx-m"><%= new Date(l.created_at).toLocaleString('fr') %></td></tr>
        <%})%>
        <%if(!recentLogs||!recentLogs.length){%><tr><td colspan="3" style="text-align:center;color:#50507a;padding:1.5rem">Aucune activité</td></tr><%}%>
      </tbody>
    </table>
  </div>
  <div class="pn">
    <div class="ph"><h3>Top actions</h3></div>
    <div class="pb">
      <div class="sl-list">
        <% (logStats||[]).slice(0,8).forEach(s=>{%>
        <div class="sl-row"><span class="sl-act"><%= s.action %></span><span class="bx bx-c"><%= s.count %></span></div>
        <%})%>
        <%if(!logStats||!logStats.length){%><p class="tx-m tx-sm" style="text-align:center;padding:1rem">Aucune donnée</p><%}%>
      </div>
    </div>
  </div>
</div>
<div class="pn mt">
  <div class="ph"><h3>Derniers prompts</h3><a href="/admin/prompts">Voir tous →</a></div>
  <table class="tbl">
    <thead><tr><th>Intention</th><th>IA cible</th><th>Modèle</th><th>Date</th></tr></thead>
    <tbody>
      <% (recentPrompts||[]).forEach(p=>{%>
      <tr><td><%= (p.intention||'').slice(0,70) %><%= p.intention&&p.intention.length>70?'...':'' %></td><td><span class="tag"><%= p.target_ai||'—' %></span></td><td class="tx-xs tx-m"><%= p.model_used||'—' %></td><td class="tx-xs tx-m"><%= new Date(p.created_at).toLocaleString('fr') %></td></tr>
      <%})%>
      <%if(!recentPrompts||!recentPrompts.length){%><tr><td colspan="4" style="text-align:center;color:#50507a;padding:1.5rem">Aucun prompt</td></tr><%}%>
    </tbody>
  </table>
</div>
V
echo "  ✓ dashboard.ejs"

# =============================================================
# views/admin/ais/index.ejs
# =============================================================
cat > views/admin/ais/index.ejs << 'V'
<div class="tb2">
  <div class="tb2-l"><a href="/admin/ais/new" class="btn btn-p">+ Ajouter une IA</a><span class="tx-m tx-sm"><%= ais.length %> IAs</span></div>
</div>
<div class="pn">
  <table class="tbl">
    <thead><tr><th>Nom</th><th>Type</th><th>Fournisseur</th><th>Prix</th><th>Difficulté</th><th>Vues</th><th>Statut</th><th>Actions</th></tr></thead>
    <tbody>
      <% ais.forEach(ai=>{%>
      <tr class="<%= !ai.is_active?'dim':'' %>">
        <td><div style="font-weight:600"><%= ai.name %><% if(ai.is_featured){%> <span class="bx bx-y">★</span><%}%></div><div class="tx-xs tx-m" style="font-family:var(--mono)"><%= ai.slug %></div></td>
        <td><span class="tag"><%= ai.type %></span></td>
        <td class="tx-sm"><%= ai.provider||'—' %></td>
        <td><span class="pr-<%= ai.pricing_type %>"><%= ai.pricing_type %></span></td>
        <td class="tx-sm tx-m"><%= ai.difficulty_level %></td>
        <td class="tx-sm"><%= ai.view_count||0 %></td>
        <td><span class="<%= ai.is_active?'on-dot':'off-dot' %>"><%= ai.is_active?'● Actif':'● Inactif' %></span></td>
        <td class="ac">
          <a href="/admin/ais/<%= ai.id %>/edit" class="btn btn-xs btn-o">✏ Modifier</a>
          <form action="/admin/ais/<%= ai.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Supprimer cette IA ?')">
            <button class="btn btn-xs btn-r">✕</button>
          </form>
        </td>
      </tr>
      <%})%>
      <%if(!ais.length){%><tr><td colspan="8" style="text-align:center;color:#50507a;padding:2rem">Aucune IA</td></tr><%}%>
    </tbody>
  </table>
</div>
V
echo "  ✓ ais/index.ejs"

# =============================================================
# views/admin/ais/form.ejs
# =============================================================
cat > views/admin/ais/form.ejs << 'V'
<div class="tb2"><div class="tb2-l"><a href="/admin/ais" class="btn btn-o btn-sm">← Retour</a></div></div>
<div class="pn"><div class="pb">
<form action="<%= action %>" method="<%= method %>" class="form">
  <div class="fg">
    <div class="fgrp"><label>Nom *</label><input type="text" name="name" value="<%= ai?ai.name:'' %>" class="fi" required></div>
    <div class="fgrp"><label>Slug</label><input type="text" name="slug" value="<%= ai?ai.slug:'' %>" class="fi" placeholder="auto-généré"></div>
    <div class="fgrp"><label>Description courte</label><input type="text" name="short_description" value="<%= ai?(ai.short_description||''):'' %>" class="fi"></div>
    <div class="fgrp"><label>Type *</label>
      <select name="type" class="fs" required>
        <option value="">-- Choisir --</option>
        <% ['text_generation','image_generation','code','audio','video','multimodal','data_analysis','search','other'].forEach(t=>{%>
        <option value="<%= t %>" <%=ai&&ai.type===t?'selected':''%>><%= t.replace(/_/g,' ') %></option>
        <%})%>
      </select>
    </div>
    <div class="fgrp"><label>Fournisseur</label><input type="text" name="provider" value="<%= ai?(ai.provider||''):'' %>" class="fi" placeholder="OpenAI, Google..."></div>
    <div class="fgrp"><label>Site web</label><input type="url" name="website_url" value="<%= ai?(ai.website_url||''):'' %>" class="fi" placeholder="https://..."></div>
    <div class="fgrp"><label>Tarification</label>
      <select name="pricing_type" class="fs">
        <% ['free','freemium','paid','open_source'].forEach(p=>{%><option value="<%= p %>" <%=ai&&ai.pricing_type===p?'selected':''%>><%= p %></option><%})%>
      </select>
    </div>
    <div class="fgrp"><label>Détail prix</label><input type="text" name="price_info" value="<%= ai?(ai.price_info||''):'' %>" class="fi" placeholder="Ex: Gratuit / 20$/mois"></div>
    <div class="fgrp"><label>Niveau</label>
      <select name="difficulty_level" class="fs">
        <% ['beginner','intermediate','advanced'].forEach(d=>{%><option value="<%= d %>" <%=ai&&ai.difficulty_level===d?'selected':''%>><%= d %></option><%})%>
      </select>
    </div>
    <div class="fgrp"><label>URL Logo</label><input type="text" name="logo_url" value="<%= ai?(ai.logo_url||''):'' %>" class="fi"></div>
  </div>
  <div class="fgrp fw"><label>Description complète *</label><textarea name="description" class="ft" rows="4" required><%= ai?ai.description:'' %></textarea></div>
  <div class="fg3">
    <div class="fgrp"><label>Points forts (1/ligne)</label><textarea name="strengths" class="ft" rows="5" placeholder="Rapide&#10;Gratuit&#10;Multimodal"><%= ai?(ai.strengths||[]).join('\n'):'' %></textarea></div>
    <div class="fgrp"><label>Limites (1/ligne)</label><textarea name="limitations" class="ft" rows="5" placeholder="Hallucinations&#10;Limite tokens"><%= ai?(ai.limitations||[]).join('\n'):'' %></textarea></div>
    <div class="fgrp"><label>Cas d'usage (1/ligne)</label><textarea name="use_cases" class="ft" rows="5" placeholder="Rédaction&#10;Code&#10;Analyse"><%= ai?(ai.use_cases||[]).join('\n'):'' %></textarea></div>
  </div>
  <div class="fgrp"><label>Tags (1/ligne)</label><textarea name="tags" class="ft" rows="2" placeholder="nlp&#10;chat&#10;code"><%= ai?(ai.tags||[]).join('\n'):'' %></textarea></div>
  <div class="fch">
    <label class="fcl"><input type="checkbox" name="is_featured" value="1" <%=ai&&ai.is_featured?'checked':''%>> Mettre en vedette</label>
    <label class="fcl"><input type="checkbox" name="is_active" value="1" <%=!ai||ai.is_active?'checked':''%>> Active</label>
  </div>
  <div class="fa">
    <a href="/admin/ais" class="btn btn-o">Annuler</a>
    <button type="submit" class="btn btn-p"><%= ai?'💾 Mettre à jour':'+ Ajouter l\'IA' %></button>
  </div>
</form>
</div></div>
V
echo "  ✓ ais/form.ejs"

# =============================================================
# views/admin/users/index.ejs
# =============================================================
cat > views/admin/users/index.ejs << 'V'
<div class="tb2">
  <div class="tb2-l"><span class="tx-m tx-sm">Total : <strong><%= total %></strong> utilisateurs</span></div>
  <div class="tb2-r">
    <div class="pagi">
      <%if(page>1){%><a href="/admin/users?page=<%= page-1 %>" class="btn btn-xs btn-o">← Préc.</a><%}%>
      <span>Page <%= page %> / <%= pages %></span>
      <%if(page<pages){%><a href="/admin/users?page=<%= page+1 %>" class="btn btn-xs btn-o">Suiv. →</a><%}%>
    </div>
  </div>
</div>
<div class="pn">
  <table class="tbl">
    <thead><tr><th>Utilisateur</th><th>Email</th><th>Rôle</th><th>Auth</th><th>Prompts</th><th>Statut</th><th>Inscrit</th><th>Actions</th></tr></thead>
    <tbody>
      <% users.forEach(u=>{%>
      <tr class="<%= !u.is_active?'dim':'' %>">
        <td><div class="uc"><div class="uav"><%= u.username[0].toUpperCase() %></div><div><div style="font-weight:500"><%= u.username %></div></div></div></td>
        <td class="tx-sm tx-m"><%= u.email %></td>
        <td><span class="bx bx-<%= u.role==='admin'?'a':'u' %>"><%= u.role %></span></td>
        <td class="tx-sm tx-m"><%= u.oauth_provider||'local' %></td>
        <td class="tx-sm"><%= u.daily_prompt_count||0 %></td>
        <td><span class="<%= u.is_active?'on-dot':'off-dot' %>"><%= u.is_active?'● Actif':'● Banni' %></span></td>
        <td class="tx-xs tx-m"><%= new Date(u.created_at).toLocaleDateString('fr') %></td>
        <td class="ac">
          <a href="/admin/users/<%= u.id %>" class="btn btn-xs btn-o">Voir</a>
          <form action="/admin/users/<%= u.id %>/role" method="POST" style="display:inline">
            <button class="btn btn-xs btn-y"><%= u.role==='admin'?'↓ User':'↑ Admin' %></button>
          </form>
          <form action="/admin/users/<%= u.id %>/toggle" method="POST" style="display:inline">
            <button class="btn btn-xs <%= u.is_active?'btn-r':'btn-g' %>"><%= u.is_active?'Bannir':'Réactiver' %></button>
          </form>
          <form action="/admin/users/<%= u.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Supprimer cet utilisateur ?')">
            <button class="btn btn-xs btn-r">✕</button>
          </form>
        </td>
      </tr>
      <%})%>
      <%if(!users.length){%><tr><td colspan="8" style="text-align:center;color:#50507a;padding:2rem">Aucun utilisateur</td></tr><%}%>
    </tbody>
  </table>
</div>
V
echo "  ✓ users/index.ejs"

# =============================================================
# views/admin/users/detail.ejs
# =============================================================
mkdir -p views/admin/users
cat > views/admin/users/detail.ejs << 'V'
<div class="tb2"><div class="tb2-l"><a href="/admin/users" class="btn btn-o btn-sm">← Retour</a></div></div>
<div style="display:grid;grid-template-columns:280px 1fr;gap:1.25rem;align-items:start">
  <div>
    <div class="pn" style="margin-bottom:1rem">
      <div class="pb" style="text-align:center;padding:1.5rem">
        <div class="sb-av" style="width:56px;height:56px;font-size:1.3rem;margin:0 auto 1rem"><%= u.username[0].toUpperCase() %></div>
        <div style="font-size:1rem;font-weight:700"><%= u.username %></div>
        <div class="tx-sm tx-m"><%= u.email %></div>
        <div style="margin-top:.75rem;display:flex;gap:.5rem;justify-content:center">
          <span class="bx bx-<%= u.role==='admin'?'a':'u' %>"><%= u.role %></span>
          <span class="<%= u.is_active?'on-dot':'off-dot' %>"><%= u.is_active?'● Actif':'● Banni' %></span>
        </div>
      </div>
      <div style="border-top:1px solid var(--bd);padding:.875rem 1rem">
        <div style="display:flex;flex-direction:column;gap:.5rem;font-size:.78rem">
          <div style="display:flex;justify-content:space-between"><span class="tx-m">Auth</span><span><%= u.oauth_provider||'local' %></span></div>
          <div style="display:flex;justify-content:space-between"><span class="tx-m">Prompts aujourd'hui</span><span><%= u.daily_prompt_count||0 %></span></div>
          <div style="display:flex;justify-content:space-between"><span class="tx-m">Inscrit le</span><span><%= new Date(u.created_at).toLocaleDateString('fr') %></span></div>
        </div>
      </div>
      <div style="border-top:1px solid var(--bd);padding:.75rem">
        <form action="/admin/users/<%= u.id %>/toggle" method="POST" style="margin-bottom:.4rem">
          <button class="btn btn-sm btn-w <%= u.is_active?'btn-r':'btn-g' %>"><%= u.is_active?'Bannir':'Réactiver' %></button>
        </form>
        <form action="/admin/users/<%= u.id %>/role" method="POST" style="margin-bottom:.4rem">
          <button class="btn btn-sm btn-y btn-w"><%= u.role==='admin'?'Retirer admin':'Rendre admin' %></button>
        </form>
        <form action="/admin/users/<%= u.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Supprimer définitivement ?')">
          <button class="btn btn-sm btn-r btn-w">Supprimer le compte</button>
        </form>
      </div>
    </div>
  </div>
  <div>
    <div class="pn" style="margin-bottom:1rem">
      <div class="ph"><h3>Prompts générés (<%= prompts.length %>)</h3></div>
      <table class="tbl">
        <thead><tr><th>Intention</th><th>IA cible</th><th>Note</th><th>Date</th></tr></thead>
        <tbody>
          <% (prompts||[]).forEach(p=>{%>
          <tr><td class="tx-sm"><%= (p.intention||'').slice(0,60) %>...</td><td><span class="tag"><%= p.target_ai||'—' %></span></td><td class="tx-sm"><%= p.rating?p.rating+'/5':'—' %></td><td class="tx-xs tx-m"><%= new Date(p.created_at).toLocaleString('fr') %></td></tr>
          <%})%>
          <%if(!prompts.length){%><tr><td colspan="4" style="text-align:center;color:#50507a;padding:1.5rem">Aucun prompt</td></tr><%}%>
        </tbody>
      </table>
    </div>
    <div class="pn">
      <div class="ph"><h3>Activité (<%= logs.length %>)</h3></div>
      <table class="tbl">
        <thead><tr><th>Action</th><th>IP</th><th>Date</th></tr></thead>
        <tbody>
          <% (logs||[]).slice(0,20).forEach(l=>{%>
          <tr><td><code style="font-size:.7rem;color:var(--a2)"><%= l.action %></code></td><td class="tx-xs tx-m"><%= l.ip_address||'—' %></td><td class="tx-xs tx-m"><%= new Date(l.created_at).toLocaleString('fr') %></td></tr>
          <%})%>
          <%if(!logs.length){%><tr><td colspan="3" style="text-align:center;color:#50507a;padding:1.5rem">Aucune activité</td></tr><%}%>
        </tbody>
      </table>
    </div>
  </div>
</div>
V
echo "  ✓ users/detail.ejs"

# =============================================================
# views/admin/prompts/index.ejs
# =============================================================
mkdir -p views/admin/prompts
cat > views/admin/prompts/index.ejs << 'V'
<div class="pn">
  <table class="tbl">
    <thead><tr><th>Intention</th><th>IA cible</th><th>User</th><th>Modèle</th><th>Note</th><th>Date</th><th>Actions</th></tr></thead>
    <tbody>
      <% (prompts||[]).forEach(p=>{%>
      <tr>
        <td class="tx-sm" style="max-width:260px"><%= (p.intention||'').slice(0,80) %>...</td>
        <td><span class="tag"><%= p.target_ai||'—' %></span></td>
        <td class="tx-sm tx-m"><%= p.user_id?'#'+p.user_id:'invité' %></td>
        <td class="tx-xs tx-m" style="font-family:var(--mono)"><%= p.model_used||'—' %></td>
        <td class="tx-sm"><%= p.rating?'★ '+p.rating+'/5':'—' %></td>
        <td class="tx-xs tx-m"><%= new Date(p.created_at).toLocaleString('fr') %></td>
        <td>
          <form action="/admin/prompts/<%= p.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Supprimer ce prompt ?')">
            <button class="btn btn-xs btn-r">✕</button>
          </form>
        </td>
      </tr>
      <%})%>
      <%if(!prompts||!prompts.length){%><tr><td colspan="7" style="text-align:center;color:#50507a;padding:2rem">Aucun prompt</td></tr><%}%>
    </tbody>
  </table>
</div>
V
echo "  ✓ prompts/index.ejs"

# =============================================================
# views/admin/roadmaps/index.ejs
# =============================================================
cat > views/admin/roadmaps/index.ejs << 'V'
<div class="tb2">
  <div class="tb2-l"><a href="/admin/roadmaps/new" class="btn btn-p">+ Ajouter Roadmap</a><span class="tx-m tx-sm"><%= roadmaps.length %> roadmaps</span></div>
</div>
<div class="pn">
  <table class="tbl">
    <thead><tr><th>Titre</th><th>Niveau</th><th>Durée</th><th>Étapes</th><th>Statut</th><th>Actions</th></tr></thead>
    <tbody>
      <% (roadmaps||[]).forEach(r=>{%>
      <tr class="<%= !r.is_active?'dim':'' %>">
        <td><div style="font-weight:600"><%= r.title %></div><div class="tx-xs tx-m"><%= (r.description||'').slice(0,60) %>...</div></td>
        <td><span class="bx <%= r.level==='beginner'?'bx-g':r.level==='intermediate'?'bx-y':'bx-r' %>"><%= r.level %></span></td>
        <td class="tx-sm tx-m"><%= r.estimated_duration||'—' %></td>
        <td class="tx-sm"><%= Array.isArray(r.steps)?r.steps.length:0 %> étapes</td>
        <td><span class="<%= r.is_active?'on-dot':'off-dot' %>"><%= r.is_active?'● Actif':'● Inactif' %></span></td>
        <td class="ac">
          <a href="/admin/roadmaps/<%= r.id %>/edit" class="btn btn-xs btn-o">✏ Modifier</a>
          <form action="/admin/roadmaps/<%= r.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Supprimer ?')">
            <button class="btn btn-xs btn-r">✕</button>
          </form>
        </td>
      </tr>
      <%})%>
      <%if(!roadmaps||!roadmaps.length){%><tr><td colspan="6" style="text-align:center;color:#50507a;padding:2rem">Aucune roadmap</td></tr><%}%>
    </tbody>
  </table>
</div>
V
echo "  ✓ roadmaps/index.ejs"

# =============================================================
# views/admin/roadmaps/form.ejs
# =============================================================
cat > views/admin/roadmaps/form.ejs << 'V'
<div class="tb2"><div class="tb2-l"><a href="/admin/roadmaps" class="btn btn-o btn-sm">← Retour</a></div></div>
<div class="pn"><div class="pb">
<form action="<%= action %>" method="<%= method %>" class="form">
  <div class="fg">
    <div class="fgrp"><label>Titre *</label><input type="text" name="title" value="<%= roadmap?roadmap.title:'' %>" class="fi" required></div>
    <div class="fgrp"><label>Niveau</label>
      <select name="level" class="fs">
        <% ['beginner','intermediate','advanced'].forEach(l=>{%><option value="<%= l %>" <%=roadmap&&roadmap.level===l?'selected':''%>><%= l %></option><%})%>
      </select>
    </div>
    <div class="fgrp"><label>Durée estimée</label><input type="text" name="estimated_duration" value="<%= roadmap?(roadmap.estimated_duration||''):'' %>" class="fi" placeholder="Ex: 2 semaines"></div>
    <div class="fgrp"><label>Audience cible</label><input type="text" name="target_audience" value="<%= roadmap?(roadmap.target_audience||''):'' %>" class="fi" placeholder="Débutants en IA..."></div>
  </div>
  <div class="fgrp"><label>Description *</label><textarea name="description" class="ft" rows="3" required><%= roadmap?roadmap.description:'' %></textarea></div>
  <div class="fgrp"><label>Étapes (1 titre par ligne)</label>
    <textarea name="steps" class="ft" rows="8" placeholder="Introduction à l'IA&#10;Comprendre les LLMs&#10;Premiers prompts&#10;Outils avancés"><%= roadmap&&Array.isArray(roadmap.steps)?roadmap.steps.map(s=>s.title).join('\n'):'' %></textarea>
    <small style="color:#50507a;font-size:.7rem">Chaque ligne = une étape. Tu pourras ajouter les détails plus tard.</small>
  </div>
  <div class="fa">
    <a href="/admin/roadmaps" class="btn btn-o">Annuler</a>
    <button type="submit" class="btn btn-p"><%= roadmap?'💾 Mettre à jour':'+ Créer la roadmap' %></button>
  </div>
</form>
</div></div>
V
echo "  ✓ roadmaps/form.ejs"

# =============================================================
# views/admin/content/flashcards.ejs
# =============================================================
cat > views/admin/content/flashcards.ejs << 'V'
<div class="g2">
  <div class="pn">
    <div class="ph"><h3>+ Ajouter une Flash Card</h3></div>
    <div class="pb">
      <form action="/admin/content/flashcards" method="POST" class="form">
        <div class="fgrp"><label>Terme *</label><input type="text" name="term" class="fi" required></div>
        <div class="fgrp"><label>Définition *</label><textarea name="definition" class="ft" rows="4" required></textarea></div>
        <div class="fgrp"><label>Exemple</label><textarea name="example" class="ft" rows="2"></textarea></div>
        <div class="fg">
          <div class="fgrp"><label>Catégorie</label><input type="text" name="category" class="fi" value="general"></div>
          <div class="fgrp"><label>Difficulté</label>
            <select name="difficulty" class="fs"><option value="1">1 — Débutant</option><option value="2">2 — Intermédiaire</option><option value="3">3 — Avancé</option></select>
          </div>
          <div class="fgrp"><label>Ordre</label><input type="number" name="order_index" class="fi" value="0"></div>
        </div>
        <button type="submit" class="btn btn-p btn-w">Ajouter la carte</button>
      </form>
    </div>
  </div>
  <div class="pn">
    <div class="ph"><h3><%= (cards||[]).length %> Flash Cards</h3></div>
    <table class="tbl">
      <thead><tr><th>Terme</th><th>Cat.</th><th>Diff.</th><th>Actions</th></tr></thead>
      <tbody>
        <% (cards||[]).forEach(c=>{%>
        <tr>
          <td><div style="font-weight:500"><%= c.term %></div><div class="tx-xs tx-m"><%= (c.definition||'').slice(0,50) %>...</div></td>
          <td><span class="tag"><%= c.category %></span></td>
          <td class="tx-sm"><%= c.difficulty %></td>
          <td class="ac">
            <a href="/admin/content/flashcards/<%= c.id %>/edit" class="btn btn-xs btn-o">✏</a>
            <form action="/admin/content/flashcards/<%= c.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Supprimer ?')">
              <button class="btn btn-xs btn-r">✕</button>
            </form>
          </td>
        </tr>
        <%})%>
        <%if(!cards||!cards.length){%><tr><td colspan="4" style="text-align:center;color:#50507a;padding:1.5rem">Aucune carte</td></tr><%}%>
      </tbody>
    </table>
  </div>
</div>
V
echo "  ✓ content/flashcards.ejs"

