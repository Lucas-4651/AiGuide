# Ajouter Prompt.delete dans models si absent
grep -q "Prompt.delete\|delete.*prompts" src/models/index.js || \
  sed -i "/recent: (limit) => db('prompts')/a\\  delete: (id) => db('prompts').where({ id }).delete()," src/models/index.js

echo ""
echo "✅ Installation complète !"
echo ""
echo "Fichiers créés :"
find views/admin views/layouts/admin.ejs src/controllers/adminController.js src/routes/admin.js -type f 2>/dev/null | sort
