cat > views/admin/settings.ejs << 'V'
<div class="pn" style="max-width:640px">
  <div class="ph"><h3>Paramètres du site</h3></div>
  <div class="pb">
    <p class="tx-m tx-sm" style="margin-bottom:1.25rem">Modifiables en temps réel sans redémarrage.</p>
    <form action="/admin/settings" method="POST" class="form">
      <% (settings||[]).forEach(s=>{%>
      <div class="fgrp">
        <label><%= s.key %><% if(s.description){%> <span style="font-weight:400;text-transform:none;color:#50507a">— <%= s.description %></span><%}%></label>
        <input type="text" name="<%= s.key %>" value="<%= s.value||'' %>" class="fi">
      </div>
      <%})%>
      <%if(!settings||!settings.length){%><p class="tx-m tx-sm">Aucun paramètre défini.</p><%}%>
