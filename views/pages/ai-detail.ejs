<!-- ============================================================
     views/pages/ai-detail.ejs  —  Detail d'une IA
     ============================================================ -->

<%
  // Passer la note initiale au script
  const initialRating = typeof myReview !== 'undefined' && myReview ? myReview.rating : 0;
%>

<!-- Passer les données au JS -->
<script>
  window.initialRating = <%= initialRating %>;
</script>

<div class="wrap" style="max-width:900px;">
  
  <!-- HEADER avec bouton retour et favoris -->
  <div class="page-header" style="text-align:left;">
    <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;flex-wrap:wrap;">
      <a href="/explore" class="btn btn-ghost btn-sm">← Retour</a>
      
      <% if(typeof user !== 'undefined' && user){ %>
        <button onclick="toggleFavDetail(<%= ai.id %>, this)" data-auth="1" class="btn btn-gh btn-sm" style="gap:.35rem">🤍 Ajouter aux favoris</button>
      <% } else { %>
        <a href="/auth/login" class="btn btn-gh btn-sm">🤍 Favoris</a>
      <% } %>
      
      <% if (ai.is_featured) { %><span class="badge badge-gold">⭐ En vedette</span><% } %>
    </div>
    
    <!-- Infos principales de l'IA -->
    <div class="ai-detail-header">
      <div class="ai-logo">
        <%= ai.name ? ai.name[0] : 'IA' %>
      </div>
      
      <div>
        <h1><%= ai.name %></h1>
        <div style="display:flex;gap:0.75rem;align-items:center;flex-wrap:wrap">
          <span class="tag"><%= (ai.type || '').replace(/_/g, ' ') %></span>
          <span class="pr-<%= ai.pricing_type %>">
            <%= ai.pricing_type === 'free' ? 'Gratuit' : ai.pricing_type === 'freemium' ? 'Freemium' : 'Payant' %>
          </span>
          <span class="dif-<%= ai.difficulty_level %>">
            <%= ai.difficulty_level === 'beginner' ? 'Débutant' : ai.difficulty_level === 'intermediate' ? 'Intermédiaire' : 'Avancé' %>
          </span>
          <% if (ai.provider) { %><span class="muted" style="font-size:0.85rem">par <%= ai.provider %></span><% } %>
        </div>
      </div>
      
      <% if (ai.website_url) { %>
      <a href="<%= ai.website_url %>" target="_blank" rel="noopener" class="btn btn-primary" style="margin-left:auto;">Visiter le site →</a>
      <% } %>
    </div>
  </div>

  <!-- GRILLE PRINCIPALE -->
  <div class="detail-grid">
    
    <!-- COLONNE DE GAUCHE -->
    <div>
      <!-- Description -->
      <div class="ai-card" style="margin-bottom:1.5rem">
        <h3 style="margin-bottom:1rem">Description</h3>
        <p class="muted" style="line-height:1.8"><%= ai.description || 'Aucune description disponible.' %></p>
      </div>

      <!-- Cas d'utilisation -->
      <% if (ai.use_cases && ai.use_cases.length > 0) { %>
      <div class="ai-card" style="margin-bottom:1.5rem">
        <h3 style="margin-bottom:1rem">Cas d'utilisation</h3>
        <ul style="list-style:none;display:flex;flex-wrap:wrap;gap:0.5rem">
          <% (typeof ai.use_cases==="string"?JSON.parse(ai.use_cases||"[]"):ai.use_cases||[]).forEach(uc => { %>
            <li><span class="tag accent">✓ <%= uc %></span></li>
          <% }) %>
        </ul>
      </div>
      <% } %>

      <!-- Points forts / Limites -->
      <div class="strengths-grid">
        <% if (ai.strengths && ai.strengths.length > 0) { %>
        <div class="ai-card">
          <h3 style="color:var(--gr);margin-bottom:0.75rem">✓ Points forts</h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.4rem">
            <% ai.strengths.forEach(s => { %><li class="muted" style="font-size:0.875rem">• <%= s %></li><% }) %>
          </ul>
        </div>
        <% } %>
        
        <% if (ai.limitations && ai.limitations.length > 0) { %>
        <div class="ai-card">
          <h3 style="color:var(--re);margin-bottom:0.75rem">✗ Limites</h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:0.4rem">
            <% ai.limitations.forEach(l => { %><li class="muted" style="font-size:0.875rem">• <%= l %></li><% }) %>
          </ul>
        </div>
        <% } %>
      </div>
    </div>

    <!-- COLONNE DE DROITE -->
    <div>
      <!-- Informations -->
      <div class="ai-card" style="margin-bottom:1rem">
        <h3 style="margin-bottom:1rem">Informations</h3>
        <div style="display:flex;flex-direction:column;gap:0.75rem;font-size:0.875rem">
          <div>
            <span class="muted">Prix :</span><br>
            <strong><%= ai.price_info || (ai.pricing_type === 'free' ? 'Gratuit' : ai.pricing_type === 'freemium' ? 'Freemium' : 'Payant') %></strong>
          </div>
          
          <% if (ai.provider) { %>
          <div>
            <span class="muted">Fournisseur :</span><br>
            <strong><%= ai.provider %></strong>
          </div>
          <% } %>
          
          <div>
            <span class="muted">Niveau :</span><br>
            <strong class="dif-<%= ai.difficulty_level %>">
              <%= ai.difficulty_level === 'beginner' ? 'Débutant' : ai.difficulty_level === 'intermediate' ? 'Intermédiaire' : 'Avancé' %>
            </strong>
          </div>
          
          <div>
            <span class="muted">Vues :</span><br>
            <strong><%= ai.view_count || 0 %></strong>
          </div>
        </div>
      </div>

      <!-- Tags -->
      <% if (ai.tags && ai.tags.length > 0) { %>
      <div class="ai-card" style="margin-bottom:1rem">
        <h3 style="margin-bottom:0.75rem">Tags</h3>
        <div class="ai-tags">
          <% ai.tags.forEach(t => { %><span class="tag">#<%= t %></span><% }) %>
        </div>
      </div>
      <% } %>

      <!-- Actions -->
      <a href="/generator?target=<%= encodeURIComponent(ai.name) %>" class="btn btn-primary btn-fw">
        ⚡ Générer un prompt pour <%= ai.name %>
      </a>
      <a href="/compare?ids=<%= ai.id %>" class="btn btn-ghost btn-fw" style="margin-top:0.5rem">
        ⚖️ Comparer avec d'autres
      </a>
    </div>
  </div>

  <!-- ===== SECTION AVIS COMMUNAUTÉ ===== -->
  <% if(typeof reviews !== 'undefined'){ %>
  <div style="margin:2rem auto 0">
    <div style="background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden">
      
      <!-- En-tête des avis -->
      <div style="padding:.875rem 1.25rem;border-bottom:1px solid var(--bd);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem">
        <div>
          <h3 style="font-size:.95rem;font-weight:700">⭐ Avis de la communauté</h3>
          <div style="font-size:.78rem;color:var(--t2);margin-top:.18rem">
            <%= reviewCount || 0 %> avis · Moyenne : <strong style="color:var(--ye)"><%= avgRating || '—' %>/5</strong>
          </div>
        </div>
        
        <% if(typeof user !== 'undefined' && user && !myReview){ %>
        <button onclick="toggleReviewForm()" class="btn btn-gh btn-sm">+ Laisser un avis</button>
        <% } %>
      </div>

      <!-- Formulaire d'avis -->
      <% if(typeof user !== 'undefined' && user){ %>
      <div id="reviewForm" style="<%= myReview ? 'display:block' : 'display:none' %>;padding:1rem;border-bottom:1px solid var(--bd);background:var(--bg3)">
        <form onsubmit="postReview(event, <%= ai.id %>)" style="display:flex;flex-direction:column;gap:.75rem">
          
          <!-- Sélecteur de note -->
          <div>
            <div style="font-size:.8rem;font-weight:600;margin-bottom:.4rem">Note</div>
            <div id="starPicker" style="display:flex;gap:.25rem">
              <% for(let n = 1; n <= 5; n++) { %>
              <span 
                data-rating="<%= n %>" 
                onclick="setRating(<%= n %>)" 
                style="font-size:1.5rem;cursor:pointer;opacity:<%= myReview && myReview.rating >= n ? '1' : '.3' %>;transition:opacity .12s"
                onmouseover="this.style.opacity='1'" 
                onmouseout="this.style.opacity='<%= myReview && myReview.rating >= n ? '1' : '.3' %>'"
              >⭐</span>
              <% } %>
            </div>
            <input type="hidden" id="ratingVal" value="<%= myReview ? myReview.rating : '' %>">
          </div>

          <!-- Commentaire -->
          <div class="form-group">
            <label>Commentaire (optionnel)</label>
            <textarea id="reviewComment" class="form-textarea" rows="2" maxlength="500" placeholder="Partage ton expérience..."><%= myReview ? (myReview.comment || '') : '' %></textarea>
          </div>

          <!-- Boutons -->
          <div style="display:flex;gap:.6rem;flex-wrap:wrap">
            <button type="submit" class="btn btn-p btn-sm">
              <%= myReview ? 'Mettre à jour' : 'Publier' %>
            </button>
            <% if(myReview){ %>
            <button type="button" onclick="deleteReview(<%= ai.id %>)" class="btn btn-re btn-sm">Supprimer</button>
            <% } %>
          </div>
        </form>
      </div>
      <% } %>

      <!-- Liste des avis -->
      <div style="padding:.5rem">
        <% if(reviews && reviews.length){ %>
          <% reviews.forEach(rv => { %>
          <div style="padding:.875rem 1rem;border-bottom:1px solid var(--bd)">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.35rem;flex-wrap:wrap;gap:.25rem">
              <div>
                <span style="font-weight:600;font-size:.83rem"><%= rv.username || 'Utilisateur' %></span>
                <span style="margin-left:.5rem">
                  <% for(let i = 1; i <= 5; i++) { %>
                  <span style="font-size:.8rem;opacity:<%= i <= rv.rating ? '1' : '.2' %>">⭐</span>
                  <% } %>
                </span>
              </div>
              <span style="font-size:.7rem;color:var(--mu)">
                <%= rv.created_at ? new Date(rv.created_at).toLocaleDateString('fr-FR') : '' %>
              </span>
            </div>
            <% if(rv.comment){ %>
            <p style="font-size:.83rem;color:var(--t2);margin-top:.25rem"><%= rv.comment %></p>
            <% } %>
          </div>
          <% }) %>
        <% } else { %>
          <div style="text-align:center;color:var(--mu);padding:2rem;font-size:.83rem">
            Aucun avis pour l'instant. Sois le premier !
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <% } %>
</div>

<!-- PLUS DE CSS/JS ICI - Tout est dans les fichiers externes -->