<div class="ph"><h1>📂 Mes Collections</h1><p>Organise et partage tes meilleurs prompts</p></div>
<div style="max-width:900px;margin:0 auto">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;align-items:start">
    <div style="background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);padding:1.35rem">
      <h3 style="font-size:.9rem;font-weight:700;margin-bottom:1rem">+ Nouvelle collection</h3>
      <form action="/collections" method="POST" style="display:flex;flex-direction:column;gap:.75rem">
        <div class="form-group"><label>Nom *</label><input type="text" name="name" class="form-input" required placeholder="Ex: Prompts Marketing"></div>
        <label style="display:flex;align-items:center;gap:.5rem;font-size:.83rem;cursor:pointer">
          <input type="checkbox" name="is_public" value="1" style="accent-color:var(--ac)"> Publique (partageable)
        </label>
        <button type="submit" class="btn btn-p btn-fw">Créer</button>
      </form>
    </div>
    <div>
      <% if(cols.length){ %>
        <% cols.forEach(c=>{ %>
        <div style="background:var(--bg2);border:1px solid var(--bd);border-radius:var(--r);padding:1rem;margin-bottom:.75rem;display:flex;justify-content:space-between;align-items:center">
          <div>
            <a href="/collections/<%= c.id %>" style="font-weight:700;color:var(--t)"><%= c.name %></a>
            <div style="font-size:.72rem;color:var(--mu);margin-top:.2rem"><%= c.is_public?'🌐 Publique':'🔒 Privée' %> · <%= new Date(c.created_at).toLocaleDateString('fr') %></div>
          </div>
          <form action="/collections/<%= c.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Supprimer ?')">
            <button class="btn btn-xs btn-re">✕</button>
          </form>
        </div>
        <% }) %>
      <% } else { %>
        <div style="text-align:center;color:var(--mu);padding:2rem">Aucune collection encore.</div>
      <% } %>
    </div>
  </div>
</div>
