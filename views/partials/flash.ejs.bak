<!-- ============================================================
     views/partials/messages.ejs
     Affichage des messages flash (succès, erreur, info)
     ============================================================ -->

<% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
<div class="alert al-ok" role="alert">
  <span>✓ <%= success_msg %></span>
  <button type="button" class="al-close" onclick="this.parentElement.remove()" aria-label="Fermer">✕</button>
</div>
<% } %>

<% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
<div class="alert al-er" role="alert">
  <span>✕ <%= error_msg %></span>
  <button type="button" class="al-close" onclick="this.parentElement.remove()" aria-label="Fermer">✕</button>
</div>
<% } %>

<% if (typeof info_msg !== 'undefined' && info_msg && info_msg.length > 0) { %>
<div class="alert al-in" role="alert">
  <span>ℹ <%= info_msg %></span>
  <button type="button" class="al-close" onclick="this.parentElement.remove()" aria-label="Fermer">✕</button>
</div>
<% } %>

<!-- Script optionnel pour auto-disparition après 5 secondes -->
<script>
(function() {
  // Faire disparaître les messages automatiquement après 5 secondes
  setTimeout(function() {
    document.querySelectorAll('.alert').forEach(function(alert) {
      if (alert) {
        alert.style.transition = 'opacity 0.5s';
        alert.style.opacity = '0';
        setTimeout(function() {
          if (alert && alert.remove) alert.remove();
        }, 500);
      }
    });
  }, 5000);
})();
</script>