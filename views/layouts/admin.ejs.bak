
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Admin' %> | AI Guide Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    /* ============================================================
       ADMIN PANEL — CSS AUTONOME (sans style.css du site public)
       ============================================================ */
    :root {
      --bg:      #09090f;
      --bg-2:    #0f0f18;
      --bg-3:    #17172a;
      --bg-4:    #1e1e35;
      --border:  #252540;
      --text:    #e2e2f0;
      --text-2:  #a0a0c0;
      --muted:   #5a5a80;
      --accent:  #7c5cfc;
      --accent2: #00d4ff;
      --green:   #00c97a;
      --red:     #ff4d6d;
      --yellow:  #ffb347;
      --radius:  10px;
      --radius-sm: 6px;
      --font:    'Syne', sans-serif;
      --mono:    'DM Mono', monospace;
      --shadow:  0 4px 24px rgba(0,0,0,0.5);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: var(--font);
      background: var(--bg);
      color: var(--text);
      display: flex;
      min-height: 100vh;
      overflow: hidden;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { color: var(--accent2); }
    code {
      font-family: var(--mono);
      font-size: 0.8em;
      background: var(--bg-4);
      padding: 0.1em 0.4em;
      border-radius: 4px;
      color: var(--accent2);
    }

    /* ── SIDEBAR ───────────────────────────────────────────── */
    .sidebar {
      width: 220px;
      flex-shrink: 0;
      background: var(--bg-2);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      height: 100vh;
      position: sticky;
      top: 0;
      overflow-y: auto;
    }
    .sidebar-brand {
      padding: 1.25rem 1rem 1rem;
      border-bottom: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }
    .sidebar-brand .logo {
      font-size: 1.1rem;
      font-weight: 800;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: 0.4rem;
    }
    .sidebar-brand .logo span { color: var(--accent); }
    .sidebar-brand .badge-admin {
      display: inline-block;
      padding: 0.15rem 0.5rem;
      background: rgba(124,92,252,0.15);
      border: 1px solid rgba(124,92,252,0.3);
      border-radius: 4px;
      font-size: 0.65rem;
      font-family: var(--mono);
      color: var(--accent);
      letter-spacing: 0.08em;
      font-weight: 700;
      width: fit-content;
    }
    .sidebar-nav {
      flex: 1;
      padding: 0.75rem 0.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.1rem;
    }
    .nav-section {
      font-size: 0.62rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--muted);
      padding: 0.75rem 0.75rem 0.25rem;
    }
    .nav-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem 0.75rem;
      border-radius: var(--radius-sm);
      font-size: 0.85rem;
      color: var(--text-2);
      transition: all 0.15s;
      cursor: pointer;
    }
    .nav-link:hover { background: var(--bg-3); color: var(--text); }
    .nav-link.active { background: rgba(124,92,252,0.12); color: var(--accent); border-left: 2px solid var(--accent); }
    .nav-link .icon { font-size: 1rem; width: 20px; text-align: center; }
    .sidebar-footer {
      padding: 1rem 0.75rem;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .sidebar-footer .admin-info {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.5rem;
      background: var(--bg-3);
      border-radius: var(--radius-sm);
    }
    .admin-avatar {
      width: 30px; height: 30px;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; font-weight: 800; color: #fff; flex-shrink: 0;
    }
    .admin-name { font-size: 0.8rem; font-weight: 600; }
    .admin-role { font-size: 0.68rem; color: var(--muted); font-family: var(--mono); }
    .btn-logout {
      display: flex; align-items: center; justify-content: center; gap: 0.4rem;
      padding: 0.45rem; border-radius: var(--radius-sm);
      background: transparent; border: 1px solid var(--border);
      color: var(--text-2); font-family: var(--font); font-size: 0.8rem;
      cursor: pointer; transition: all 0.15s;
    }
    .btn-logout:hover { background: rgba(255,77,109,0.1); border-color: var(--red); color: var(--red); }

    /* ── MAIN ──────────────────────────────────────────────── */
    .admin-main {
      flex: 1;
      display: flex;
      flex-direction: column;
      min-width: 0;
      height: 100vh;
      overflow-y: auto;
    }
    .admin-topbar {
      height: 56px;
      background: var(--bg-2);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.75rem;
      position: sticky;
      top: 0;
      z-index: 50;
      flex-shrink: 0;
    }
    .topbar-title {
      font-size: 1rem;
      font-weight: 700;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .topbar-title .breadcrumb {
      font-size: 0.75rem;
      color: var(--muted);
      font-family: var(--mono);
    }
    .topbar-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.8rem;
      color: var(--muted);
    }
    .topbar-right a {
      color: var(--text-2);
      font-size: 0.8rem;
      padding: 0.3rem 0.6rem;
      border-radius: var(--radius-sm);
      border: 1px solid var(--border);
      transition: all 0.15s;
    }
    .topbar-right a:hover { border-color: var(--accent); color: var(--accent); }
    .admin-body {
      padding: 1.75rem;
      flex: 1;
    }

    /* ── ALERTS ────────────────────────────────────────────── */
    .alert {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.75rem 1rem; border-radius: var(--radius-sm);
      margin-bottom: 1.25rem; font-size: 0.875rem;
      animation: slideIn 0.2s ease;
    }
    @keyframes slideIn { from { opacity:0; transform: translateY(-8px); } to { opacity:1; transform: none; } }
    .alert-success { background: rgba(0,201,122,0.08); border: 1px solid rgba(0,201,122,0.25); color: var(--green); }
    .alert-error   { background: rgba(255,77,109,0.08); border: 1px solid rgba(255,77,109,0.25); color: var(--red); }
    .alert-info    { background: rgba(0,212,255,0.08);  border: 1px solid rgba(0,212,255,0.25);  color: var(--accent2); }

    /* ── STATS GRID ────────────────────────────────────────── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1rem;
      margin-bottom: 1.75rem;
    }
    .stat-card {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem;
      display: flex;
      align-items: center;
      gap: 1rem;
      transition: border-color 0.2s;
    }
    .stat-card:hover { border-color: var(--accent); }
    .stat-icon {
      width: 44px; height: 44px;
      border-radius: var(--radius-sm);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.25rem; flex-shrink: 0;
    }
    .stat-icon.blue   { background: rgba(124,92,252,0.12); }
    .stat-icon.cyan   { background: rgba(0,212,255,0.12); }
    .stat-icon.green  { background: rgba(0,201,122,0.12); }
    .stat-icon.yellow { background: rgba(255,179,71,0.12); }
    .stat-info { display: flex; flex-direction: column; gap: 0.1rem; }
    .stat-val   { font-size: 1.8rem; font-weight: 800; line-height: 1; }
    .stat-val.blue   { color: var(--accent); }
    .stat-val.cyan   { color: var(--accent2); }
    .stat-val.green  { color: var(--green); }
    .stat-val.yellow { color: var(--yellow); }
    .stat-label { font-size: 0.78rem; color: var(--muted); }

    /* ── PANELS ────────────────────────────────────────────── */
    .panel-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
    .panel {
      background: var(--bg-2);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }
    .panel-header {
      padding: 0.875rem 1.25rem;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .panel-header h3 { font-size: 0.85rem; font-weight: 700; color: var(--text-2); }
    .panel-header a  { font-size: 0.75rem; color: var(--accent); }
    .panel-body { padding: 1rem 1.25rem; }
    .mt-5 { margin-top: 1.25rem; }

    /* ── TABLE ─────────────────────────────────────────────── */
    .admin-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; }
    .admin-table th {
      text-align: left;
      padding: 0.6rem 0.875rem;
      background: var(--bg-3);
      border-bottom: 1px solid var(--border);
      font-size: 0.72rem; font-weight: 700;
      color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em;
      white-space: nowrap;
    }
    .admin-table td {
      padding: 0.7rem 0.875rem;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }
    .admin-table tr:last-child td { border-bottom: none; }
    .admin-table tr:hover td { background: rgba(255,255,255,0.02); }
    .row-inactive { opacity: 0.4; }
    .actions-cell { display: flex; gap: 0.35rem; align-items: center; flex-wrap: wrap; }

    /* ── BUTTONS ───────────────────────────────────────────── */
    .btn {
      display: inline-flex; align-items: center; gap: 0.35rem;
      padding: 0.45rem 1rem; border-radius: var(--radius-sm);
      font-family: var(--font); font-size: 0.83rem; font-weight: 600;
      cursor: pointer; border: none; transition: all 0.15s;
      text-decoration: none; white-space: nowrap;
    }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: #6a4de8; color: #fff; }
    .btn-ghost { background: transparent; color: var(--text-2); border: 1px solid var(--border); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); background: rgba(124,92,252,0.06); }
    .btn-danger { background: rgba(255,77,109,0.1); color: var(--red); border: 1px solid rgba(255,77,109,0.25); }
    .btn-danger:hover { background: var(--red); color: #fff; }
    .btn-success { background: rgba(0,201,122,0.1); color: var(--green); border: 1px solid rgba(0,201,122,0.25); }
    .btn-success:hover { background: var(--green); color: #fff; }
    .btn-sm  { padding: 0.3rem 0.7rem; font-size: 0.78rem; }
    .btn-xs  { padding: 0.2rem 0.5rem; font-size: 0.73rem; }
    .btn-full { width: 100%; justify-content: center; }

    /* ── BADGES & TAGS ─────────────────────────────────────── */
    .tag {
      display: inline-block; padding: 0.15rem 0.45rem;
      background: var(--bg-4); border: 1px solid var(--border);
      border-radius: 4px; font-size: 0.7rem; color: var(--text-2);
      font-family: var(--mono);
    }
    .badge {
      display: inline-block; padding: 0.15rem 0.5rem;
      border-radius: 99px; font-size: 0.7rem; font-weight: 700;
    }
    .badge-admin { background: rgba(124,92,252,0.15); color: var(--accent); }
    .badge-user  { background: var(--bg-4); color: var(--text-2); }
    .badge-gold  { background: rgba(255,179,71,0.15); color: var(--yellow); }
    .badge-count { background: var(--bg-4); color: var(--text-2); font-family: var(--mono); }

    .status-active   { color: var(--green); font-size: 0.78rem; font-weight: 700; }
    .status-inactive { color: var(--red);   font-size: 0.78rem; font-weight: 700; }

    .pricing-free        { color: var(--green);  font-size: 0.78rem; font-weight: 600; }
    .pricing-freemium    { color: var(--accent2); font-size: 0.78rem; font-weight: 600; }
    .pricing-paid        { color: var(--yellow);  font-size: 0.78rem; font-weight: 600; }
    .pricing-open_source { color: #a0e080;        font-size: 0.78rem; font-weight: 600; }

    /* ── TOOLBAR ───────────────────────────────────────────── */
    .toolbar {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 1.25rem;
    }
    .toolbar-left  { display: flex; gap: 0.75rem; align-items: center; }
    .toolbar-right { display: flex; gap: 0.75rem; align-items: center; }
    .pagination    { display: flex; align-items: center; gap: 0.5rem; font-size: 0.82rem; color: var(--muted); }

    /* ── FORMS ─────────────────────────────────────────────── */
    .admin-form { display: flex; flex-direction: column; gap: 1.25rem; max-width: 960px; }
    .form-grid   { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 1rem; }
    .form-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    .full-width  { grid-column: 1 / -1; }
    .form-group  { display: flex; flex-direction: column; gap: 0.35rem; }
    .form-group label {
      font-size: 0.75rem; font-weight: 700; color: var(--muted);
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    .form-input, .form-select, .form-textarea {
      width: 100%; padding: 0.55rem 0.8rem;
      background: var(--bg-3); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text);
      font-family: var(--font); font-size: 0.875rem;
      transition: border-color 0.15s;
    }
    .form-input:focus, .form-select:focus, .form-textarea:focus {
      outline: none; border-color: var(--accent);
    }
    .form-input::placeholder { color: var(--muted); }
    .form-select option { background: var(--bg-2); }
    .form-textarea { resize: vertical; min-height: 80px; }
    .form-checks { display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center; }
    .check-label { display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.875rem; }
    .check-label input { accent-color: var(--accent); width: 15px; height: 15px; }
    .form-actions { display: flex; gap: 0.75rem; padding-top: 0.5rem; }

    /* ── USER CELL ─────────────────────────────────────────── */
    .user-cell { display: flex; align-items: center; gap: 0.6rem; }
    .user-avatar-sm {
      width: 28px; height: 28px; border-radius: 50%;
      background: linear-gradient(135deg, var(--accent), var(--accent2));
      display: flex; align-items: center; justify-content: center;
      font-size: 0.72rem; font-weight: 800; color: #fff; flex-shrink: 0;
    }

    /* ── STATS LIST ────────────────────────────────────────── */
    .stats-list { display: flex; flex-direction: column; }
    .stats-row {
      display: flex; justify-content: space-between; align-items: center;
      padding: 0.45rem 0; border-bottom: 1px solid var(--border);
    }
    .stats-row:last-child { border-bottom: none; }
    .stats-action { font-family: var(--mono); font-size: 0.77rem; color: var(--text-2); }

    /* ── GRID 2 COL ────────────────────────────────────────── */
    .admin-grid-2 { display: grid; grid-template-columns: 360px 1fr; gap: 1.75rem; align-items: start; }

    /* ── UTILS ─────────────────────────────────────────────── */
    .text-muted { color: var(--muted); }
    .text-xs    { font-size: 0.73rem; }
    .text-sm    { font-size: 0.82rem; }
    .mt-4       { margin-top: 1rem; }
    .mt-5       { margin-top: 1.25rem; }

    /* ── RESPONSIVE ────────────────────────────────────────── */
    @media (max-width: 1100px) {
      .panel-grid    { grid-template-columns: 1fr; }
      .admin-grid-2  { grid-template-columns: 1fr; }
      .form-grid-3   { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 768px) {
      .sidebar       { display: none; }
      .admin-body    { padding: 1rem; }
      .admin-topbar  { padding: 0 1rem; }
      .form-grid-3   { grid-template-columns: 1fr; }
      .stats-grid    { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 480px) {
      .stats-grid    { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <div class="sidebar-brand">
      <div class="logo"><span>◈</span> AI Guide</div>
      <span class="badge-admin">ADMIN PANEL</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="nav-link <%= currentPath === '/admin' ? 'active' : '' %>">
        <span class="icon">📊</span> Dashboard
      </a>

      <div class="nav-section">Contenu IA</div>
      <a href="/admin/ais" class="nav-link <%= currentPath && currentPath.startsWith('/admin/ais') ? 'active' : '' %>">
        <span class="icon">🤖</span> Gestion IAs
      </a>
      <a href="/admin/ais/new" class="nav-link">
        <span class="icon">➕</span> Ajouter IA
      </a>

      <div class="nav-section">Apprentissage</div>
      <a href="/admin/content/flashcards" class="nav-link <%= currentPath && currentPath.includes('flashcards') ? 'active' : '' %>">
        <span class="icon">🃏</span> Flash Cards
      </a>
      <a href="/admin/content/tips" class="nav-link <%= currentPath && currentPath.includes('tips') ? 'active' : '' %>">
        <span class="icon">💡</span> Astuces
      </a>

      <div class="nav-section">Communauté</div>
      <a href="/admin/users" class="nav-link <%= currentPath && currentPath.startsWith('/admin/users') ? 'active' : '' %>">
        <span class="icon">👥</span> Utilisateurs
      </a>

      <div class="nav-section">Système</div>
      <a href="/admin/logs" class="nav-link <%= currentPath === '/admin/logs' ? 'active' : '' %>">
        <span class="icon">📋</span> Logs & Métriques
      </a>
      <a href="/admin/settings" class="nav-link <%= currentPath === '/admin/settings' ? 'active' : '' %>">
        <span class="icon">⚙️</span> Paramètres
      </a>

      <div class="nav-section">Navigation</div>
      <a href="/" class="nav-link" target="_blank">
        <span class="icon">🌐</span> Voir le site
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="admin-info">
        <div class="admin-avatar"><%= user ? user.username[0].toUpperCase() : 'A' %></div>
        <div>
          <div class="admin-name"><%= user ? user.username : 'Admin' %></div>
          <div class="admin-role">administrator</div>
        </div>
      </div>
      <a href="/admin/logout" class="btn-logout">⏻ Déconnexion</a>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="admin-main">
    <header class="admin-topbar">
      <div class="topbar-title">
        <span><%- typeof title !== 'undefined' ? title : 'Admin' %></span>
        <span class="breadcrumb">/ AI Guide Admin</span>
      </div>
      <div class="topbar-right">
        <span><%= user ? user.email : '' %></span>
        <a href="/" target="_blank">← Site public</a>
      </div>
    </header>

    <div class="admin-body">
      <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
        <div class="alert alert-success">✓ &nbsp;<%= success_msg %></div>
      <% } %>
      <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="alert alert-error">⚠ &nbsp;<%= error_msg %></div>
      <% } %>
      <% if (typeof info_msg !== 'undefined' && info_msg && info_msg.length > 0) { %>
        <div class="alert alert-info">ℹ &nbsp;<%= info_msg %></div>
      <% } %>

      <%- body %>
    </div>
  </div>

  <script>
    // Auto-dismiss alerts
    document.querySelectorAll('.alert').forEach(el => {
      setTimeout(() => el.style.display = 'none', 4000);
    });
    // Slug auto-gen
    const nameInput = document.querySelector('input[name="name"]');
    const slugInput = document.querySelector('input[name="slug"]');
    if (nameInput && slugInput) {
      nameInput.addEventListener('input', () => {
        if (!slugInput.dataset.manual) {
          slugInput.value = nameInput.value.toLowerCase().trim()
            .replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
        }
      });
      slugInput.addEventListener('input', () => { slugInput.dataset.manual = '1'; });
    }
  </script>
</body>
</html>
